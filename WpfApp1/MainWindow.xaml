<Window
    x:Class="WpfApp1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Telegram IDM"
    Width="500"
    Height="500">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ===================== CONFIG =====================  -->
        <GroupBox
            Margin="0,0,0,10"
            Padding="10"
            Header="⚙️ Cấu hình Telegram">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  BOT TOKEN  -->
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Bot Token:" />

                <StackPanel Grid.Row="0" Grid.Column="1">
                    <TextBox
                        x:Name="BotTokenBox"
                        Margin="0,2"
                        Text="8252286058:AAHAxRwyjpgUX50NrclSMRivynJKl_8J5QE" />
                    <TextBlock
                        FontSize="11"
                        Foreground="Gray"
                        Text="Lấy từ @BotFather trên Telegram" />
                </StackPanel>

                <!--  API ID  -->
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="API ID:" />

                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBox
                        x:Name="ApiIdBox"
                        Margin="0,2"
                        Text="38846110" />
                    <TextBlock
                        FontSize="11"
                        Foreground="Gray"
                        Text="Lấy tại https://my.telegram.org" />
                </StackPanel>

                <!--  API HASH  -->
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="API Hash:" />

                <StackPanel Grid.Row="2" Grid.Column="1">
                    <TextBox
                        x:Name="ApiHashBox"
                        Margin="0,2"
                        Text="4401d761c36050d83d767fbe9007a076" />
                    <TextBlock
                        FontSize="11"
                        Foreground="Gray"
                        Text="Chuỗi bảo mật đi kèm API ID" />
                </StackPanel>

                <!--  PHONE  -->
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Phone:" />

                <StackPanel Grid.Row="3" Grid.Column="1">
                    <TextBox x:Name="PhoneBox" Margin="0,2" />
                    <TextBlock
                        FontSize="11"
                        Foreground="Gray"
                        Text="Số Telegram (+84...) để login WTelegram" />
                </StackPanel>

            </Grid>
        </GroupBox>

        <!--  START BUTTON  -->
        <Button
            Grid.Row="0"
            Height="35"
            Margin="0,0,0,10"
            HorizontalAlignment="Right"
            Click="Start_Click"
            Content="🟟 Start Bot + Downloader" />

        <!--  ===================== DOWNLOAD LIST =====================  -->
        <GroupBox Grid.Row="1" Header="🟟 Danh sách download">

            <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding Downloads}">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Width="auto"
                        Binding="{Binding FileName}"
                        Header="File" />

                    <DataGridTemplateColumn Width="200" Header="Progress">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ProgressBar
                                    Height="18"
                                    Maximum="100"
                                    Value="{Binding Progress}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>


                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Status}"
                        Header="Status" />

                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>
    </Grid>
</Window>