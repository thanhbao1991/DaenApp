<Window
    x:Class="WpfApp1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Telegram Video Professional Crawler"
    Width="1100"
    Height="750"
    Background="#F5F5F5">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox
            Margin="0,0,0,10"
            Padding="10"
            Header="Cấu hình Telegram">
            <UniformGrid Columns="3">
                <StackPanel Margin="5">
                    <TextBlock Text="API ID:" />
                    <TextBox x:Name="ApiIdBox" Padding="3" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="API Hash:" />
                    <TextBox x:Name="ApiHashBox" Padding="3" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Số điện thoại:" />
                    <TextBox x:Name="PhoneBox" Padding="3" />
                </StackPanel>
            </UniformGrid>
        </GroupBox>

        <GroupBox
            Grid.Row="1"
            Margin="0,0,0,10"
            Padding="10"
            Header="Bộ lọc &amp; Điều khiển">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="Từ ngày:" />
                <DatePicker
                    x:Name="FromDatePicker"
                    Width="120"
                    Margin="10,0" />
                <TextBlock VerticalAlignment="Center" Text="Đến ngày:" />
                <DatePicker
                    x:Name="ToDatePicker"
                    Width="120"
                    Margin="10,0" />
                <Button
                    x:Name="StartBtn"
                    Width="100"
                    Margin="20,0,0,0"
                    Background="#0078D7"
                    Click="Start_Click"
                    Content="Bắt đầu"
                    FontWeight="Bold"
                    Foreground="White" />
            </StackPanel>
        </GroupBox>

        <GroupBox
            Grid.Row="2"
            Margin="0,0,0,10"
            Padding="10"
            Header="Trạng thái hệ thống">
            <StackPanel>
                <TextBlock
                    x:Name="StatusLabel"
                    FontWeight="Bold"
                    Foreground="#2D2D2D"
                    Text="Sẵn sàng" />
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="CurrentGroupLabel"
                        Grid.Column="0"
                        Text="Nhóm: -" />
                    <TextBlock
                        x:Name="CurrentDayLabel"
                        Grid.Column="1"
                        Text="Ngày quét: -" />
                </Grid>
            </StackPanel>
        </GroupBox>

        <DataGrid
            x:Name="DownloadGrid"
            Grid.Row="3"
            AlternatingRowBackground="#FAFAFA"
            AutoGenerateColumns="False"
            Background="White"
            IsReadOnly="True"
            ItemsSource="{Binding Downloads}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding GroupName}"
                    Header="Nhóm" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding FileName}"
                    Header="Tên File" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding CrawlDay, StringFormat=dd/MM/yyyy}"
                    Header="Ngày crawl" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Status}"
                    Header="Trạng thái">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="*" Header="Tiến độ tải">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="4">
                                <ProgressBar
                                    Height="15"
                                    Maximum="100"
                                    Value="{Binding Progress}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontWeight="Bold"
                                    Text="{Binding Progress, StringFormat={}{0:F1}%}" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
