<UserControl
    x:Class="TraSuaApp.WpfClient.Views.ThongKeTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F4F6F8"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <UserControl.Resources>
        <!--  strong headers  -->
        <SolidColorBrush x:Key="GreenHeader" Color="#34C759" />
        <SolidColorBrush x:Key="BlueHeader" Color="#007AFF" />
        <SolidColorBrush x:Key="OrangeHeader" Color="#FF9500" />
        <SolidColorBrush x:Key="RedHeader" Color="#FF3B30" />

        <!--  body tints (slightly stronger than before for readability)  -->
        <SolidColorBrush x:Key="GreenTint" Color="#DFF8E8" />
        <SolidColorBrush x:Key="BlueTint" Color="#E6F0FF" />
        <SolidColorBrush x:Key="OrangeTint" Color="#FFF6E6" />
        <SolidColorBrush x:Key="RedTint" Color="#FFF2F2" />

        <!--  common  -->
        <Style x:Key="CardBase" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="BorderBrush" Value="#E6E9EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="14"
                        Opacity="0.12"
                        ShadowDepth="0" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardHeaderText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="AmountText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!--  row border style with hover  -->
        <Style x:Key="RowBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#00FFFFFF" />
            <!--  transparent base  -->
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="2,4" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Cursor" Value="Arrow" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFFFFFFF" />
                    <Setter Property="BorderBrush" Value="#E2E8F0" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Cursor" Value="Hand" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="12">
        <UniformGrid Columns="4">

            <!--  DOANH THU  -->
            <Border Style="{StaticResource CardBase}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Background="{StaticResource GreenHeader}"
                        CornerRadius="10,10,0,0">
                        <DockPanel Margin="12,8">
                            <TextBlock
                                DockPanel.Dock="Left"
                                Style="{StaticResource CardHeaderText}"
                                Text="Doanh thu" />
                            <TextBlock
                                x:Name="TongDoanhThuTextBlock"
                                DockPanel.Dock="Right"
                                Foreground="White"
                                Style="{StaticResource AmountText}" />
                        </DockPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Background="{StaticResource GreenTint}"
                        CornerRadius="0,0,10,10">
                        <StackPanel Margin="12">
                            <!--  inner white panel to make text high-contrast  -->
                            <Border
                                Padding="10"
                                Background="#FFFFFFFF"
                                CornerRadius="8"
                                Opacity="0.95">
                                <StackPanel>
                                    <StackPanel x:Name="DoanhThuNgayStackPanel" />
                                </StackPanel>
                            </Border>

                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    x:Name="PrevButton"
                                    Width="30"
                                    Height="30"
                                    Click="PrevButton_Click">
                                    ◀
                                </Button>
                                <Border
                                    Margin="8,0"
                                    Padding="6"
                                    Background="#F1F5F9"
                                    CornerRadius="6">
                                    <TextBlock
                                        x:Name="DateTextBlock"
                                        FontWeight="Bold"
                                        Foreground="#334155" />
                                </Border>
                                <Button
                                    x:Name="NextButton"
                                    Width="30"
                                    Height="30"
                                    Click="NextButton_Click">
                                    ▶
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!--  THANH TOÁN  -->
            <Border Style="{StaticResource CardBase}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Background="{StaticResource BlueHeader}"
                        CornerRadius="10,10,0,0">
                        <DockPanel Margin="12,8">
                            <TextBlock
                                DockPanel.Dock="Left"
                                Style="{StaticResource CardHeaderText}"
                                Text="Thanh toán" />
                            <TextBlock
                                x:Name="TongThanhToanTextBlock"
                                DockPanel.Dock="Right"
                                Foreground="White"
                                Style="{StaticResource AmountText}"
                                />
                        </DockPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Background="{StaticResource BlueTint}"
                        CornerRadius="0,0,10,10">
                        <StackPanel Margin="12">
                            <Border
                                Padding="10"
                                Background="#FFFFFFFF"
                                CornerRadius="8"
                                Opacity="0.95">
                                <StackPanel>
                                    <StackPanel x:Name="TienMatStackPanel" />
                                    <StackPanel x:Name="ChuyenKhoanStackPanel" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!--  CÔNG NỢ  -->
            <Border Style="{StaticResource CardBase}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Background="{StaticResource OrangeHeader}"
                        CornerRadius="10,10,0,0">
                        <DockPanel Margin="12,8">
                            <TextBlock
                                DockPanel.Dock="Left"
                                Style="{StaticResource CardHeaderText}"
                                Text="Công nợ" />
                            <TextBlock
                                x:Name="TongCongNoTextBlock"
                                DockPanel.Dock="Right"
                                Foreground="White"
                                Style="{StaticResource AmountText}" />
                        </DockPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Background="{StaticResource OrangeTint}"
                        CornerRadius="0,0,10,10">
                        <StackPanel Margin="12">
                            <Border
                                Padding="10"
                                Background="#FFFFFFFF"
                                CornerRadius="8"
                                Opacity="0.95">
                                <StackPanel>
                                    <StackPanel x:Name="CongNoNgayStackPanel" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!--  CHI TIÊU  -->
            <Border Style="{StaticResource CardBase}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Background="{StaticResource RedHeader}"
                        CornerRadius="10,10,0,0">
                        <DockPanel Margin="12,8">
                            <TextBlock
                                DockPanel.Dock="Left"
                                Style="{StaticResource CardHeaderText}"
                                Text="Chi tiêu" />
                            <TextBlock
                                x:Name="TongChiTieuTextBlock"
                                DockPanel.Dock="Right"
                                Foreground="White"
                                Style="{StaticResource AmountText}" />
                        </DockPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Background="{StaticResource RedTint}"
                        CornerRadius="0,0,10,10">
                        <StackPanel Margin="12">
                            <Border
                                Padding="10"
                                Background="#FFFFFFFF"
                                CornerRadius="8"
                                Opacity="0.95">
                                <StackPanel>
                                    <StackPanel x:Name="ChiTieuNgayStackPanel" />
                                    <Separator Margin="0,8" />
                                    <StackPanel x:Name="ChiTieuThangStackPanel" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

        </UniformGrid>
    </Grid>
</UserControl>