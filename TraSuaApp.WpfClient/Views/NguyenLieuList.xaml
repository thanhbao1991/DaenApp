<Window
    x:Class="TraSuaApp.WpfClient.SettingsViews.NguyenLieuList"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:TraSuaApp.WpfClient.Controls"
    xmlns:local="clr-namespace:TraSuaApp.WpfClient.SettingsViews"
    Style="{StaticResource PopupWindowWithBorderStyle}"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:NguyenLieuBanHangNameConverter x:Key="NguyenLieuBanHangNameConverter" />
        <local:NguyenLieuBanHangDonViConverter x:Key="NguyenLieuBanHangDonViConverter" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Name="TieuDeTextBlock" Style="{StaticResource TitleTextStyle}" />
            <Button
                Click="CloseButton_Click"
                DockPanel.Dock="Right"
                Style="{StaticResource CloseButtonStyle}" />
        </DockPanel>

        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,4,0">
                <TextBox
                    x:Name="SearchTextBox"
                    Style="{StaticResource SearchTextBoxStyle}"
                    TextChanged="SearchTextBox_TextChanged" />
                <TextBlock
                    Style="{StaticResource SearchHintTextStyle}"
                    Text="Tìm kiếm..."
                    Visibility="{Binding Text.IsEmpty, ElementName=SearchTextBox, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="AddButton_Click"
                    Content="Thêm"
                    Style="{StaticResource AddButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="EditButton_Click"
                    Content="Sửa"
                    Style="{StaticResource EditButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="DeleteButton_Click"
                    Content="Xoá"
                    Style="{StaticResource DeleteButtonStyle}" />
                <Button
                    Width="80"
                    Click="ReloadButton_Click"
                    Content="Tải lại"
                    Style="{StaticResource ReloadButtonStyle}" />
            </StackPanel>
        </Grid>

        <DataGrid
            x:Name="NguyenLieuDataGrid"
            Grid.Row="2"
            Margin="10"
            AutoGenerateColumns="False"
            CanUserSortColumns="False"
            MouseDoubleClick="NguyenLieuDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding Stt}"
                    ElementStyle="{StaticResource CenterTextCellStyle}"
                    Header="STT" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Ten}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Tên nguyên liệu" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding GiaNhap, StringFormat={}{0:N0}}"
                    ElementStyle="{StaticResource RightTextCellStyle}"
                    Header="Giá nhập" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding DonViTinh}"
                    ElementStyle="{StaticResource CenterTextCellStyle}"
                    Header="ĐVT nhập" />
                <DataGridTextColumn
                    Width="90"
                    Binding="{Binding HeSoQuyDoiBanHang, StringFormat={}{0:0.####}}"
                    ElementStyle="{StaticResource RightTextCellStyle}"
                    Header="Hệ số" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding NguyenLieuBanHangId, Converter={StaticResource NguyenLieuBanHangDonViConverter}}"
                    ElementStyle="{StaticResource CenterTextCellStyle}"
                    Header="ĐVT bán" />
                <DataGridTextColumn
                    Width="180"
                    Binding="{Binding NguyenLieuBanHangId, Converter={StaticResource NguyenLieuBanHangNameConverter}}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Nguyên liệu bán" />
                <DataGridCheckBoxColumn
                    Width="90"
                    Binding="{Binding DangSuDung}"
                    Header="Đang dùng" />
            </DataGrid.Columns>
        </DataGrid>

        <Border
            Grid.Row="3"
            Margin="10,10,10,0"
            Padding="10"
            Background="WhiteSmoke"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="8">

            <StackPanel>
                <TextBlock
                    x:Name="FormTitleTextBlock"
                    Margin="0,0,0,8"
                    FontWeight="SemiBold"
                    Text="Thêm nguyên liệu" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="Tên nguyên liệu" />
                    <TextBox
                        x:Name="TenTextBox"
                        Grid.Column="1"
                        Height="30"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Stretch" />

                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Text="ĐVT nhập" />
                    <TextBox
                        x:Name="DonViTinhTextBox"
                        Grid.Column="3"
                        Height="30"
                        HorizontalAlignment="Stretch" />
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="Giá nhập" />
                    <ctrl:MoneyTextBox
                        x:Name="GiaNhapTextBox"
                        Grid.Column="1"
                        Height="30"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Stretch" />

                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Text="Hệ số" />
                    <ctrl:NumericTextBox
                        x:Name="HeSoQuyDoiNumeric"
                        Grid.Column="3"
                        Height="30"
                        HorizontalAlignment="Stretch" />
                </Grid>

                <GroupBox Margin="0,0,0,8" Header="Nguyên liệu bán hàng">
                    <ctrl:NguyenLieuBanHangSearchBox x:Name="NguyenLieuBanHangSearchBox" HorizontalAlignment="Stretch" />
                </GroupBox>

                <CheckBox
                    x:Name="DangSuDungCheckBox"
                    Margin="0,0,0,8"
                    Content="Đang dùng" />

                <TextBlock
                    x:Name="ErrorTextBlock"
                    Margin="0,0,0,6"
                    Style="{StaticResource ErrorTextBlock}" />

                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="SaveButton"
                        Width="100"
                        Margin="0,0,6,0"
                        Click="SaveButton_Click"
                        Content="Thêm"
                        Style="{StaticResource AddButtonStyle}" />
                    <Button
                        Width="100"
                        Click="CancelEditButton_Click"
                        Content="Huỷ"
                        Style="{StaticResource ReloadButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>