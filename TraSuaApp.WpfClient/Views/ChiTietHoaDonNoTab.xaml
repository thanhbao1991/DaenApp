<UserControl
    x:Class="TraSuaApp.WpfClient.Views.ChiTietHoaDonNoTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ================= Toolbar =================  -->

        <DockPanel Grid.Row="0" Margin="4">

            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <TextBlock
                    Padding="8"
                    VerticalAlignment="Center"
                    Text="Tìm kiếm:" />

                <TextBox
                    x:Name="SearchChiTietHoaDonNoTextBox"
                    Width="320"
                    Margin="8,0,0,0"
                    TextChanged="SearchChiTietHoaDonNoTextBox_TextChanged" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">

                <Button
                    Click="TimKiemNhanhCongNoButton_Click"
                    Content="Công nợ hôm nay"
                    Foreground="White"
                    Style="{StaticResource ThemButtonStyle}"
                    Tag="hôm nay" />

                <Button
                    Click="TimKiemNhanhCongNoButton_Click"
                    Content="Công nợ hôm qua"
                    Foreground="White"
                    Style="{StaticResource ThemButtonStyle}"
                    Tag="hôm qua" />
            </StackPanel>

        </DockPanel>

        <!--  ================= DataGrid =================  -->

        <DataGrid
            x:Name="ChiTietHoaDonNoDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            EnableColumnVirtualization="True"
            EnableRowVirtualization="True"
            IsReadOnly="True">

            <!--  Row Style  -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}" />
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <DataGridTextColumn
                    Binding="{Binding Stt}"
                    ElementStyle="{StaticResource CenterTextCellStyle}"
                    Header="STT" />

                <DataGridTextColumn
                    Binding="{Binding NgayNo, StringFormat={}{0:dd-MM-yyyy}}"
                    ElementStyle="{StaticResource CenterTextCellStyle}"
                    Header="Ngày" />

                <DataGridTextColumn
                    Binding="{Binding NgayNo, StringFormat={}{0:HH:mm}}"
                    ElementStyle="{StaticResource CenterTextCellStyle}"
                    Header="Giờ" />

                <DataGridTextColumn
                    Binding="{Binding TenKhachHangText}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Tên" />

                <DataGridTextColumn
                    x:Name="TongTienChiTietHoaDonNoTextBlock"
                    Binding="{Binding ConLai, StringFormat={}{0:N0}}"
                    ElementStyle="{StaticResource RightTextCellStyle}"
                    Header="Còn lại" />

                <!--  ===== Buttons =====  -->

                <DataGridTemplateColumn Width="Auto" Header="(Thu nhanh nhấn giữ Ctrl)">

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>

                            <StackPanel Orientation="Horizontal">

                                <!--  Tiền mặt  -->

                                <Button
                                    Padding="6,3"
                                    Background="Transparent"
                                    Click="TienMatRowButton_Click"
                                    Style="{StaticResource EditButtonStyle}">

                                    <StackPanel Orientation="Horizontal">

                                        <fa:IconImage
                                            Width="16"
                                            Height="16"
                                            Foreground="{StaticResource SuccessBrush}"
                                            Icon="MoneyBill" />

                                        <TextBlock
                                            Margin="6,0,0,0"
                                            Foreground="{StaticResource SuccessBrush}"
                                            Text="TM" />

                                    </StackPanel>

                                </Button>

                                <!--  Chuyển khoản  -->

                                <Button
                                    Margin="8,0,0,0"
                                    Padding="6,3"
                                    Background="Transparent"
                                    Click="ChuyenKhoanRowButton_Click"
                                    Style="{StaticResource EditButtonStyle}">

                                    <StackPanel Orientation="Horizontal">

                                        <fa:IconImage
                                            Width="16"
                                            Height="16"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            Icon="CreditCard" />

                                        <TextBlock
                                            Margin="6,0,0,0"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            Text="Chuyển khoản" />

                                    </StackPanel>

                                </Button>

                            </StackPanel>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding GhiChu}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Ghi chú" />

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>