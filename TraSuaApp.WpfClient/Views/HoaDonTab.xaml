<UserControl
    x:Class="TraSuaApp.WpfClient.Views.HoaDonTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp">
    <UserControl.Resources>
        <Style x:Key="RoundAvatarStyle" TargetType="Image">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Stretch" Value="Fill" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Clip">
                <Setter.Value>
                    <EllipseGeometry
                        Center="13,13"
                        RadiusX="13"
                        RadiusY="13" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!--  ship chưa giao thì ẩn  -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding PhanLoai}" Value="Ship" />
                        <Condition Binding="{Binding NgayShip}" Value="{x:Null}" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <!--  Progress bar ẩn: phục vụ SafeButtonHandlerAsync; không thay đổi UI  -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  === PHẦN BẠN ĐÃ GỬI (nguyên vẹn) ===  -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />

            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  ProgressBar ẩn, nằm chung hàng với ô tìm kiếm để không ảnh hưởng layout  -->
            <ProgressBar
                x:Name="ProgressBar"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Height="2"
                Margin="0,0,0,4"
                IsIndeterminate="True"
                Visibility="Collapsed" />
            <DockPanel Background="White">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button
                        HorizontalAlignment="Left"
                        Panel.ZIndex="1"
                        Click="AddTaiChoButton_Click"
                        Style="{StaticResource SuaButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,5,0" Icon="Chair" />
                            <TextBlock Text="Tại chỗ" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="8,0,0,0"
                        HorizontalAlignment="Left"
                        Panel.ZIndex="1"
                        Click="AddMuaVeButton_Click"
                        Style="{StaticResource TaiLaiButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,5,0" Icon="ShoppingBag" />
                            <TextBlock Text="Mua về" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="8,0,0,0"
                        HorizontalAlignment="Left"
                        Panel.ZIndex="1"
                        Click="AddShipButton_Click"
                        Style="{StaticResource ThemButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,5,0" Icon="Motorcycle" />
                            <TextBlock Text="Ship" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="8,0,0,0"
                        HorizontalAlignment="Left"
                        Panel.ZIndex="1"
                        Click="AddMuaHoButton_Click"
                        Style="{StaticResource XoaButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,5,0" Icon="Mobile" />
                            <TextBlock Text="Mua hộ" />
                        </StackPanel>
                    </Button>
                    <Button
                        Name="AppButton"
                        Margin="8,0,0,0"
                        Click="AppButton_Click"
                        Style="{StaticResource ReloadButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="16"
                                Height="16"
                                Icon="Heart" />
                            <TextBlock Margin="5,0,0,0" Text="Bắt Đơn App" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="8,0,0,0"
                        HorizontalAlignment="Left"
                        Panel.ZIndex="1"
                        Click="AddAppButton_Click"
                        Style="{StaticResource XoaButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,5,0" Icon="Mobile" />
                            <TextBlock Text="App" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock
                        Padding="8"
                        VerticalAlignment="Center"
                        Foreground="Black"
                        Text="Tìm kiếm:" />
                    <TextBox
                        x:Name="SearchHoaDonTextBox"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Width="320"
                        TextChanged="SearchHoaDonTextBox_TextChanged" />
                </StackPanel>
            </DockPanel>
            <DataGrid
                x:Name="HoaDonDataGrid"
                Grid.Row="1"
                Grid.Column="0"
                AutoGenerateColumns="False"
                EnableColumnVirtualization="True"
                EnableRowVirtualization="True"
                IsReadOnly="True"
                IsSynchronizedWithCurrentItem="True"
                MouseDoubleClick="HoaDonDataGrid_MouseDoubleClick"
                SelectionChanged="HoaDonDataGrid_SelectionChangedAsync"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.ScrollUnit="Pixel"
                VirtualizingPanel.VirtualizationMode="Standard"
                Visibility="Visible">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Binding="{Binding Stt}"
                        ElementStyle="{StaticResource CenterTextCellStyle}"
                        Header="STT"
                        Visibility="Collapsed" />

                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding NgayGio, StringFormat=HH:mm}"
                        ElementStyle="{StaticResource RightTextCellStyle}"
                        Header="" />
                    <DataGridTextColumn Width=" 60" Binding="{Binding WaitingTime}">
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource CenterTextCellStyle}" TargetType="TextBlock">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FontWeight" Value="Regular" />
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="FontSize" Value="8" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WaitingTime}" Value="Mới">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryForeground}" />
                                        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel
                                    Height="32"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                                    <!--  Khánh  -->
                                    <Image Source="/Images/khanh.jpg">
                                        <Image.Style>
                                            <Style BasedOn="{StaticResource RoundAvatarStyle}" TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NguoiShip}" Value="Khánh">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <!--  Nhã  -->
                                    <Image Source="/Images/nha.jpg">
                                        <Image.Style>
                                            <Style BasedOn="{StaticResource RoundAvatarStyle}" TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NguoiShip}" Value="Nhã">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding TenKhachHangText}"
                        Header="Tên bàn/khách">
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource LeftTextCellStyle}" TargetType="TextBlock">
                                <!--  mặc định  -->
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="Black" />
                                <Style.Triggers>

                                    <!--  Nhóm 1: ship chưa giao  -->
                                    <DataTrigger Binding="{Binding SortOrder}" Value="1">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryForeground}" />
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>

                                    <!--  Nhóm 2: chưa xử lý  -->
                                    <DataTrigger Binding="{Binding SortOrder}" Value="2">
                                        <Setter Property="Foreground" Value="{StaticResource WarningForeground}" />
                                        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SortOrder}" Value="4">
                                        <Setter Property="Foreground" Value="{StaticResource WarningForeground}" />
                                        <Setter Property="Background" Value="LightGreen" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SortOrder}" Value="3">
                                        <Setter Property="Foreground" Value="{StaticResource DangerForeground}" />
                                        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>

                                    <!--  Nhóm 3: ship đã giao chưa xử lý  -->
                                    <DataTrigger Binding="{Binding SortOrder}" Value="5">
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>

                                    <!--  Nhóm 5: nợ  -->
                                    <DataTrigger Binding="{Binding SortOrder}" Value="7">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="Red" />
                                    </DataTrigger>

                                    <!--  Nhóm 4: đã thanh  -->
                                    <DataTrigger Binding="{Binding SortOrder}" Value="6">
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding SortOrder}"
                        ElementStyle="{StaticResource LeftTextCellStyle}"
                        Header="SortOrder"
                        Visibility="Collapsed" />
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding PhanLoai}"
                        ElementStyle="{StaticResource LeftTextCellStyle}"
                        Header="PhanLoai"
                        Visibility="Collapsed" />
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding NguoiShip}"
                        ElementStyle="{StaticResource LeftTextCellStyle}"
                        Header="NguoiShip"
                        Visibility="Collapsed" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding GhiChuShipper}"
                        FontSize="8">
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource CenterTextCellStyle}" TargetType="TextBlock">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FontWeight" Value="Regular" />
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="FontSize" Value="8" />
                                <!--<Style.Triggers>
                                    <DataTrigger Binding="{Binding GhiChuShipper}" Value="Tí nữa chuyển khoản">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryForeground}" />
                                        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBank}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryForeground}" />
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>-->
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        x:Name="ThanhTienColumn"
                        Width="Auto"
                        Binding="{Binding ThanhTien, StringFormat=N0}"
                        ElementStyle="{StaticResource LeftTextCellStyle}"
                        Header="T.Tiền"
                        Visibility="Collapsed" />
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding DaThu, StringFormat=N0}"
                        ElementStyle="{StaticResource RightTextCellStyle}"
                        Header="Đã thu"
                        Visibility="Collapsed" />
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding ConLai, StringFormat=N0}"
                        ElementStyle="{StaticResource RightTextCellStyle}"
                        Header="Còn lại"
                        Visibility="Collapsed" />
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding NgayNo, StringFormat=HH:mm}"
                        ElementStyle="{StaticResource RightTextCellStyle}"
                        Header="Ghi nợ"
                        Visibility="Collapsed" />
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding IsBank}"
                        ElementStyle="{StaticResource RightTextCellStyle}"
                        Visibility="Collapsed" />

                    <DataGridTemplateColumn Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Width="40"
                                        MinWidth="0"
                                        HorizontalAlignment="Center"
                                        Click="RollBack_Click"
                                        Style="{StaticResource ThemButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconImage
                                                Width="16"
                                                Height="16"
                                                Foreground="{StaticResource PrimaryBrush}"
                                                Icon="CircleArrowLeft" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <Grid
                x:Name="RightPanelGrid"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                Background="DodgerBlue">

                <ScrollViewer
                    x:Name="ThongTinThanhToanGroupBox"
                    Background="Transparent"
                    HorizontalScrollBarVisibility="Disabled"
                    PreviewMouseWheel="ThongTinThanhToanGroupBox_PreviewMouseWheel"
                    VerticalScrollBarVisibility="Auto">

                    <StackPanel
                        x:Name="HoaDonDetailPanel"
                        Margin="8"
                        Opacity="0"
                        Visibility="Collapsed">

                        <!--  HEADER  -->
                        <Border
                            Margin="0,0,0,8"
                            Padding="10"
                            Background="#F6F8FB"
                            CornerRadius="8">

                            <Grid>
                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="16" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Foreground" Value="#1E3A8A" />
                                    </Style>
                                </Grid.Resources>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Name="DiemThangTruocTextBlock"
                                    Grid.Column="0"
                                    Margin="10,0"
                                    HorizontalAlignment="Left"
                                    FontWeight="Regular"
                                    Foreground="#64748B"
                                    TextDecorations="Strikethrough" />

                                <TextBlock
                                    x:Name="TenHoaDonTextBlock"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Foreground="#0F172A"
                                    TextTrimming="CharacterEllipsis" />

                                <TextBlock
                                    x:Name="DiemThangNayTextBlock"
                                    Grid.Column="2"
                                    Margin="10,0"
                                    HorizontalAlignment="Right"
                                    Foreground="DodgerBlue" />
                            </Grid>
                        </Border>

                        <!--  LIST  -->
                        <ListBox
                            x:Name="ChiTietHoaDonListBox"
                            Margin="0,4,0,0"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            ScrollViewer.CanContentScroll="False"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            SelectionChanged="ChiTietHoaDonListBox_SelectionChanged">

                            <ListBox.ItemTemplate>
                                <DataTemplate>

                                    <Border
                                        Margin="0,0,0,6"
                                        Padding="10"
                                        HorizontalAlignment="Left"
                                        Background="#F8FAFC"
                                        CornerRadius="8">

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="auto" />
                                                <ColumnDefinition Width="90" />
                                            </Grid.ColumnDefinitions>

                                            <!--  BADGE  -->
                                            <Border
                                                Width="30"
                                                Height="30"
                                                VerticalAlignment="Top"
                                                Background="DodgerBlue"
                                                CornerRadius="15">

                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding SoLuong}" />

                                            </Border>

                                            <!--  INFO  -->
                                            <StackPanel Grid.Column="1" Margin="8,0,8,0">

                                                <StackPanel Orientation="Horizontal">

                                                    <TextBlock
                                                        FontWeight="Bold"
                                                        Foreground="#1E3A8A"
                                                        Text="{Binding TenSanPham}" />

                                                    <TextBlock
                                                        Margin="4,0,0,0"
                                                        FontWeight="SemiBold"
                                                        Foreground="#DC2626"
                                                        Text="{Binding TenBienThe}">

                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />

                                                                <Style.Triggers>

                                                                    <DataTrigger Binding="{Binding TenBienThe}" Value="Size Chuẩn">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding TenBienThe}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding TenBienThe}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>

                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>

                                                    </TextBlock>

                                                </StackPanel>

                                                <!--  TOPPING  -->
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="{StaticResource FontSizeSmall}"
                                                    Foreground="#059669"
                                                    Text="{Binding ToppingText}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding ToppingText, Converter={StaticResource NullOrEmptyOrDefaultToVisibilityConverter}}" />

                                                <!--  NOTE  -->
                                                <TextBox
                                                    Margin="0,2,0,0"
                                                    AcceptsReturn="True"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="{StaticResource FontSizeNormal}"
                                                    Foreground="#059669"
                                                    Text="{Binding NoteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding NoteText, Converter={StaticResource NullOrEmptyOrDefaultToVisibilityConverter}}" />

                                                <!--  DINH LUONG  -->
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="{StaticResource FontSizeSmall}"
                                                    Foreground="DodgerBlue"
                                                    Text="{Binding DinhLuong}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding DinhLuong, Converter={StaticResource NullOrEmptyOrDefaultToVisibilityConverter}}" />

                                            </StackPanel>

                                            <!--  PRICE  -->
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">

                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontWeight="Bold"
                                                    Foreground="#DC2626"
                                                    Text="{Binding ThanhTien, StringFormat={}{0:N0}}" />

                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    HorizontalAlignment="Right"
                                                    FontSize="{StaticResource FontSizeSmall}"
                                                    Foreground="#64748B"
                                                    Opacity="0.8"
                                                    Text="{Binding NgayGio, StringFormat=HH:mm}"
                                                    Visibility="{Binding NgayGio, Converter={StaticResource NullOrEmptyOrDefaultToVisibilityConverter}}" />

                                            </StackPanel>

                                        </Grid>

                                    </Border>

                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!--  FOOTER  -->
                        <Border
                            Margin="0,10,0,0"
                            Padding="10"
                            Background="Transparent"
                            CornerRadius="8"
                            Visibility="{Binding ElementName=TongSoSanPhamTextBlock, Path=Visibility}">

                            <StackPanel>

                                <StackPanel x:Name="ThongTinThanhToanPanel" Margin="0,0,0,6" />


                            </StackPanel>

                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!--  BUSY  -->
                <Border
                    x:Name="RightBusyOverlay"
                    Background="#40FFFFFF"
                    Visibility="Collapsed">

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                        <ProgressBar
                            Width="160"
                            Height="6"
                            IsIndeterminate="True" />

                        <TextBlock
                            Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="#1E3A8A"
                            Opacity="0.8"
                            Text="Đang tải chi tiết hoá đơn..." />

                    </StackPanel>

                </Border>
                <TextBlock
                    x:Name="TongSoSanPhamTextBlock"
                    Margin="0,-100,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeXXX}"
                    FontWeight="Bold"
                    Foreground="#1E3A8A"
                    Opacity="0.7"
                    TextAlignment="Center" />
            </Grid>
            <Grid
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="#f0f0f0">
                <StackPanel x:Name="HoaDonButtonStack" Orientation="Horizontal">
                    <Button
                        Name="EscButton"
                        Margin="5"
                        Background="{StaticResource PrimaryBrush}"
                        Click="EscButton_Click"
                        Foreground="{StaticResource LightBrush}"
                        Style="{StaticResource AddButtonStyle}"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="16"
                                Height="16"
                                Foreground="{StaticResource LightBrush}"
                                Icon="Motorcycle" />
                            <TextBlock Margin="5,0,0,0" Text=" Esc - KHÁNH" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="F1Button"
                        Margin="5"
                        Click="F1Button_Click"
                        Style="{StaticResource EditButtonStyle}"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="16"
                                Height="16"
                                Foreground="{StaticResource LightBrush}"
                                Icon="MoneyBill" />
                            <TextBlock Margin="5,0,0,0" Text=" F1 - Tiền mặt" />
                        </StackPanel>
                    </Button>
                    <Button
                        Name="F2Button"
                        Margin="5"
                        Background="Transparent"
                        Click="F2Button_Click"
                        Foreground="{StaticResource DarkBrush}"
                        Style="{StaticResource AddButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="16"
                                Height="16"
                                Foreground="{StaticResource DarkBrush}"
                                Icon="Print" />
                            <TextBlock Margin="5,0,0,0" Text=" F2 - In bill" />
                        </StackPanel>
                    </Button>
                    <Button
                        Name="F3Button"
                        Margin="5"
                        Background="Transparent"
                        Click="F3Button_Click"
                        Foreground="{StaticResource DarkBrush}"
                        Style="{StaticResource AddButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="16"
                                Height="16"
                                Foreground="{StaticResource DarkBrush}"
                                Icon="ShareSquare" />
                            <TextBlock Margin="5,0,0,0" Text=" F3 - Gửi bill" />
                        </StackPanel>
                    </Button>
                    <Button
                        Name="F4Button"
                        Margin="5"
                        Click="F4Button_Click"
                        Foreground="{StaticResource DarkBrush}"
                        Style="{StaticResource AddButtonStyle}"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="16"
                                Height="16"
                                Foreground="{StaticResource DarkBrush}"
                                Icon="CreditCard" />
                            <TextBlock Margin="5,0,0,0" Text=" F4 - Chuyển khoản" />
                        </StackPanel>
                    </Button>
                    <Button
                        Name="F12Button"
                        Margin="5"
                        Click="F12Button_Click"
                        Style="{StaticResource XoaButtonStyle}"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="16"
                                Height="16"
                                Foreground="{StaticResource DangerBrush}"
                                Icon="PencilAlt" />
                            <TextBlock Margin="5,0,0,0" Text=" F12 - Ghi nợ" />
                        </StackPanel>
                    </Button>
                    <Button
                        Name="DelButton"
                        Margin="5"
                        Click="DelButton_Click"
                        Style="{StaticResource XoaButtonStyle}"
                        Visibility="Visible">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="16"
                                Height="16"
                                Foreground="{StaticResource DangerBrush}"
                                Icon="Trash" />
                            <TextBlock Margin="5,0,0,0" Text=" Del - Xoá" />
                        </StackPanel>
                    </Button>


                    <Button
                        Name="F9Button"
                        Margin="5"
                        Background="Transparent"
                        Click="F9Button_Click"
