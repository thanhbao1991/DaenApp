<Window
    x:Class="TraSuaApp.WpfClient.SettingsViews.KhachHangGiaBanList"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:TraSuaApp.WpfClient.Controls"
    Style="{StaticResource PopupWindowWithBorderStyle}"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Tiêu đề  -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Name="TieuDeTextBlock" Style="{StaticResource TitleTextStyle}" />
            <Button
                Click="CloseButton_Click"
                DockPanel.Dock="Right"
                Style="{StaticResource CloseButtonStyle}" />
        </DockPanel>

        <!--  Thanh công cụ  -->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,4,0">
                <TextBox
                    x:Name="SearchTextBox"
                    Style="{StaticResource SearchTextBoxStyle}"
                    TextChanged="SearchTextBox_TextChanged" />
                <TextBlock
                    Style="{StaticResource SearchHintTextStyle}"
                    Text="Tìm kiếm theo KH / SP / Biến thể / Giá..."
                    Visibility="{Binding Text.IsEmpty, ElementName=SearchTextBox, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="AddButton_Click"
                    Content="Thêm"
                    IsEnabled="False"
                    Style="{StaticResource AddButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="EditButton_Click"
                    Content="Sửa"
                    Style="{StaticResource EditButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="DeleteButton_Click"
                    Content="Xoá"
                    Style="{StaticResource DeleteButtonStyle}" />
                <Button
                    Width="80"
                    Click="ReloadButton_Click"
                    Content="Tải lại"
                    Style="{StaticResource ReloadButtonStyle}" />
            </StackPanel>
        </Grid>

        <!--  Danh sách  -->
        <DataGrid
            x:Name="KhachHangGiaBanDataGrid"
            Grid.Row="2"
            Margin="10"
            AutoGenerateColumns="False"
            CanUserSortColumns="False"
            IsReadOnly="True"
            MouseDoubleClick="KhachHangGiaBanDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding Stt}"
                    ElementStyle="{StaticResource CenterTextCellStyle}"
                    Header="STT" />
                <DataGridTextColumn
                    Width="180"
                    Binding="{Binding TenKhachHang}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Khách hàng" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding TenSanPham}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Sản phẩm" />
                <DataGridTextColumn
                    Width="200"
                    Binding="{Binding TenBienThe}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Biến thể" />
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding GiaBan, StringFormat={}{0:N0}}"
                    ElementStyle="{StaticResource RightTextCellStyle}"
                    Header="Giá bán" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Form nhập  -->
        <Border
            Grid.Row="3"
            Margin="10,10,10,0"
            Padding="10"
            Background="WhiteSmoke"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="FormTitleTextBlock"
                    Grid.ColumnSpan="4"
                    Margin="0,0,0,6"
                    FontWeight="SemiBold"
                    Text="Cập nhật giá bán" />

                <TextBlock
                    x:Name="SelectedInfoTextBlock"
                    Grid.Row="1"
                    Grid.ColumnSpan="4"
                    Margin="0,0,0,8"
                    TextWrapping="Wrap" />

                <!--  Giá bán  -->
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Giá bán" />
                <ctrl:NumericTextBox
                    x:Name="GiaBanTextBox"
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="30"
                    MinWidth="160"
                    HorizontalAlignment="Left" />

                <TextBlock
                    x:Name="ErrorTextBlock"
                    Grid.Row="3"
                    Grid.ColumnSpan="4"
                    Margin="0,8,0,6"
                    Style="{StaticResource ErrorTextBlock}" />

                <StackPanel
                    Grid.Row="4"
                    Grid.ColumnSpan="4"
                    Orientation="Horizontal">
                    <Button
                        x:Name="SaveButton"
                        Width="100"
                        Margin="0,0,6,0"
                        Click="SaveButton_Click"
                        Content="Lưu"
                        Style="{StaticResource EditButtonStyle}" />
                    <Button
                        Width="100"
                        Click="CancelEditButton_Click"
                        Content="Huỷ"
                        Style="{StaticResource ReloadButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>