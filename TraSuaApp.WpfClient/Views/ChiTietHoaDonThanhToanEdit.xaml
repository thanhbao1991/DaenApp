<Window
    x:Class="TraSuaApp.WpfClient.HoaDonViews.ChiTietHoaDonThanhToanEdit"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:TraSuaApp.WpfClient.Controls"
    Loaded="Window_Loaded"
    Style="{StaticResource EditWindowStyle}"
    WindowStartupLocation="CenterScreen">

    <Border Style="{StaticResource EditFormBorderStyle}">
        <Grid Margin="16">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  HEADER  -->
            <DockPanel Grid.Row="0" Style="{StaticResource EditHeaderPanelStyle}">
                <TextBlock x:Name="TieuDeTextBlock" Style="{StaticResource EditTitleTextStyle}" />

                <Button
                    Click="CloseButton_Click"
                    Content="✖"
                    Style="{StaticResource CloseButtonStyle}" />
            </DockPanel>


            <!--  FORM  -->
            <Grid Grid.Row="1" Margin="0,0,0,10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>


                <!--  Ngày  -->
                <GroupBox
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,8,8"
                    Header="Ngày">
                    <TextBox x:Name="NgayTextBox" IsEnabled="False" />
                </GroupBox>

                <!--  Giờ  -->
                <GroupBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,0,8"
                    Header="Giờ">
                    <TextBox x:Name="GioTextBox" IsEnabled="False" />
                </GroupBox>


                <!--  Khách  -->
                <GroupBox
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,8,8"
                    Header="Tên bàn/khách">
                    <TextBox x:Name="TenTextBox" IsEnabled="False" />
                </GroupBox>

                <!--  Loại thanh toán  -->
                <GroupBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,0,0,8"
                    Header="Loại thanh toán">
                    <TextBox x:Name="LoaiThanhToanTextBox" IsEnabled="False" />
                </GroupBox>


                <!--  Số tiền  -->
                <GroupBox
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Header="Số tiền">
                    <ctrl:NumericTextBox x:Name="SoTienTextBox" />
                </GroupBox>

                <!--  Phương thức  -->
                <GroupBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Header="Phương thức">
                    <ComboBox
                        x:Name="PhuongThucThanhToanComboBox"
                        DisplayMemberPath="Ten"
                        SelectedValuePath="Id"
                        SelectionChanged="PhuongThucThanhToanComboBox_SelectionChanged" />
                </GroupBox>

            </Grid>


            <!--  FOOTER  -->
            <StackPanel Grid.Row="2">

                <TextBlock x:Name="ErrorTextBlock" Style="{StaticResource ErrorTextBlock}" />

                <Button
                    Name="SaveButton"
                    Click="SaveButton_Click"
                    Content="Lưu"
                    Style="{StaticResource SaveButtonStyle}" />

            </StackPanel>

        </Grid>
    </Border>
</Window>