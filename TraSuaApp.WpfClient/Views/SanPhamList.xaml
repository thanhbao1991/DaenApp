<Window
    x:Class="TraSuaApp.WpfClient.SettingsViews.SanPhamList"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:TraSuaApp.WpfClient.Controls"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  TOOLBAR  -->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,4,0">
                <TextBox
                    x:Name="SearchTextBox"
                    Style="{StaticResource SearchTextBoxStyle}"
                    TextChanged="SearchTextBox_TextChanged" />
                <TextBlock
                    Style="{StaticResource SearchHintTextStyle}"
                    Text="Tìm kiếm..."
                    Visibility="{Binding Text.IsEmpty, ElementName=SearchTextBox, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="AddButton_Click"
                    Content="Thêm"
                    Style="{StaticResource AddButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="EditButton_Click"
                    Content="Sửa"
                    Style="{StaticResource EditButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="DeleteButton_Click"
                    Content="Xoá"
                    Style="{StaticResource DeleteButtonStyle}" />
                <Button
                    Width="80"
                    Click="ReloadButton_Click"
                    Content="Tải lại"
                    Style="{StaticResource ReloadButtonStyle}" />
            </StackPanel>
        </Grid>

        <!--  DATA GRID  -->
        <DataGrid
            x:Name="SanPhamDataGrid"
            Grid.Row="2"
            Margin="10"
            AutoGenerateColumns="False"
            CanUserSortColumns="False"
            MouseDoubleClick="SanPhamDataGrid_MouseDoubleClick">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NgungBan}" Value="True">
                            <Setter Property="Opacity" Value="0.25" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="auto"
                    Binding="{Binding Stt}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="STT" />
                <DataGridTextColumn
                    Width="auto"
                    Binding="{Binding TenNhomSanPham}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Nhóm" />
                <DataGridTextColumn
                    Width="Auto"
                    Binding="{Binding Ten}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Tên" />
                <DataGridTextColumn
                    Width="auto"
                    Binding="{Binding GiaHienThi}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Giá" />
                <DataGridTextColumn
                    Width="auto"
                    Binding="{Binding VietTat}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Viết tắt" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  FORM  -->
        <Border
            x:Name="FormPanel"
            Grid.Row="3"
            Margin="10,10,10,0"
            Padding="12"
            Background="WhiteSmoke"
            BorderBrush="#DDD"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="Collapsed">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  TITLE  -->
                <TextBlock
                    Grid.ColumnSpan="4"
                    Margin="0,0,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Thông tin sản phẩm" />

                <!--  TÊN  -->
                <TextBlock Grid.Row="1" Text="Tên sản phẩm" />
                <TextBox
                    x:Name="TenTextBox"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,0,10,0" />

                <CheckBox
                    x:Name="TichDiemCheck"
                    Grid.Row="1"
                    Grid.Column="3"
                    Content="Tích điểm" />

                <!--  VIẾT TẮT  -->
                <TextBlock Grid.Row="2" Text="Viết tắt" />
                <TextBox
                    x:Name="VietTatTextBox"
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,0,10,0" />

                <CheckBox
                    x:Name="NgungBanCheck"
                    Grid.Row="2"
                    Grid.Column="3"
                    Content="Ngưng bán" />

                <!--  NHÓM  -->
                <TextBlock Grid.Row="3" Text="Nhóm sản phẩm" />
                <ComboBox
                    x:Name="ComboNhom"
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,0,10,0" />

                <!--  BIẾN THỂ  -->
                <TextBlock
                    Grid.Row="4"
                    Margin="0,6,0,0"
                    Text="Biến thể" />

                <StackPanel
                    Grid.Row="4"
                    Grid.Column="1"
                    Grid.ColumnSpan="3">

                    <!--  INPUT  -->
                    <StackPanel Orientation="Horizontal">


                        <TextBox
                            x:Name="BienTheTextBox"
                            Width="100"
                            Margin="0,0,8,0" />
                        <ctrl:MoneyTextBox
                            x:Name="GiaBanTextBox"
                            Width="75"
                            Margin="0,0,8,0" />

                        <!--  ✅ ĐỊNH LƯỢNG  -->
                        <TextBox
                            x:Name="DinhLuongVariantTextBox"
                            MinWidth="400"
                            Margin="0,0,4,0"
                            HorizontalAlignment="Stretch" />

                        <Button
                            x:Name="SaveVariantButton"
                            Click="SaveVariantButton_Click"
                            Content="Thêm"
                            Style="{StaticResource ThemButtonStyle}" />

                        <Button
                            x:Name="CancelVariantButton"
                            Click="CancelVariantButton_Click"
                            Content="Huỷ"
                            Style="{StaticResource TaiLaiButtonStyle}" />
                    </StackPanel>

                </StackPanel>

                <!--  LIST BIẾN THỂ  -->
                <GroupBox
                    Grid.Row="5"
                    Grid.ColumnSpan="4"
                    Margin="0,10,0,0"
                    Header="Danh sách biến thể">
                    <ListBox
                        x:Name="BienTheListBox"
                        Height="120"
                        SelectionChanged="VariantListBox_SelectionChanged">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Padding="4"
                                        FontWeight="Bold"
                                        Text="{Binding TenBienThe}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Padding="4"
                                        FontWeight="Bold"
                                        Text="{Binding GiaBan, StringFormat=N0}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        FontStyle="Italic"
                                        Padding="4"
                                        Text="{Binding DinhLuong}" />

                                    <CheckBox
                                        Grid.Column="3"
                                        Padding="4"
                                        Click="MacDinhCheckBox_Click"
                                        Content="Mặc định"
                                        IsChecked="{Binding MacDinh}" />

                                    <Button
                                        Grid.Column="4"
                                        Padding="4"
                                        Click="XoaVariant_Click"
                                        Content="Xóa"
                                        Style="{StaticResource XoaButtonStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <!--  ERROR  -->
                <TextBlock
                    x:Name="ErrorTextBlock"
                    Grid.Row="6"
                    Grid.ColumnSpan="4"
                    Margin="0,8,0,6"
                    Style="{StaticResource ErrorTextBlock}" />

                <!--  SAVE  -->
                <Button
                    x:Name="SaveButton"
                    Grid.Row="7"
                    Grid.ColumnSpan="4"
                    Height="36"
                    Click="SaveButton_Click"
                    Content="Lưu"
                    Style="{StaticResource SaveButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Window>