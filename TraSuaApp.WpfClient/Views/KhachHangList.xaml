<Window
    x:Class="TraSuaApp.WpfClient.SettingsViews.KhachHangList"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Style="{StaticResource EditWindowStyle}"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Tiêu đề  -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Name="TieuDeTextBlock" Style="{StaticResource TitleTextStyle}" />
            <Button
                Click="CloseButton_Click"
                DockPanel.Dock="Right"
                Style="{StaticResource CloseButtonStyle}" />
        </DockPanel>

        <!--  Thanh công cụ  -->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,4,0">
                <TextBox
                    x:Name="SearchTextBox"
                    Style="{StaticResource SearchTextBoxStyle}"
                    TextChanged="SearchTextBox_TextChanged" />
                <TextBlock
                    Style="{StaticResource SearchHintTextStyle}"
                    Text="Tìm kiếm tên / SĐT / địa chỉ..."
                    Visibility="{Binding Text.IsEmpty, ElementName=SearchTextBox, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="AddButton_Click"
                    Content="Thêm"
                    Style="{StaticResource AddButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="EditButton_Click"
                    Content="Sửa"
                    Style="{StaticResource EditButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,4,0"
                    Click="DeleteButton_Click"
                    Content="Xoá"
                    Style="{StaticResource DeleteButtonStyle}" />
                <Button
                    Width="80"
                    Click="ReloadButton_Click"
                    Content="Tải lại"
                    Style="{StaticResource ReloadButtonStyle}" />
            </StackPanel>
        </Grid>

        <!--  Danh sách  -->
        <DataGrid
            x:Name="KhachHangDataGrid"
            Grid.Row="2"
            Margin="10"
            AutoGenerateColumns="False"
            CanUserSortColumns="False"
            MouseDoubleClick="KhachHangDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding Stt}"
                    ElementStyle="{StaticResource CenterTextCellStyle}"
                    Header="STT" />
                <DataGridTextColumn
                    Width="160"
                    Binding="{Binding Ten}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Tên khách hàng" />
                <DataGridTextColumn
                    Width="140"
                    Binding="{Binding DienThoai}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Điện thoại" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding DiaChi}"
                    ElementStyle="{StaticResource LeftTextCellStyle}"
                    Header="Địa chỉ" />
                <DataGridCheckBoxColumn
                    Width="110"
                    Binding="{Binding DuocNhanVoucher}"
                    Header="Nhận voucher" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Form  -->
        <Border
            Grid.Row="3"
            Margin="10,10,10,0"
            Padding="10"
            Background="WhiteSmoke"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    x:Name="FormTitleTextBlock"
                    Grid.Row="0"
                    Margin="0,0,0,6"
                    FontWeight="SemiBold"
                    Text="Thêm khách hàng" />

                <TextBlock
                    x:Name="SelectedInfoTextBlock"
                    Grid.Row="1"
                    Margin="0,0,0,8"
                    Foreground="{StaticResource SecondaryBrush}"
                    Text="Nhập thông tin khách hàng bên dưới." />

                <GroupBox
                    Grid.Row="2"
                    Margin="0,0,0,6"
                    Header="Thông tin khách hàng">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,8,4"
                            VerticalAlignment="Center"
                            Text="Tên khách:" />
                        <TextBox
                            x:Name="TenTextBox"
                            Grid.Row="0"
                            Grid.Column="1"
                            Height="30"
                            HorizontalAlignment="Stretch" />

                        <CheckBox
                            x:Name="DuocNhanVoucherCheckBox"
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,8,0,0"
                            Content="Được nhận voucher" />
                    </Grid>
                </GroupBox>

                <GroupBox
                    Grid.Row="3"
                    Margin="0,0,0,6"
                    Header="Số điện thoại">
                    <DockPanel Margin="4">
                        <Button
                            x:Name="AddPhoneButton"
                            Margin="0,0,0,4"
                            Padding="6,2"
                            HorizontalAlignment="Right"
                            Click="AddPhoneButton_Click"
                            Content="+ Thêm SĐT"
                            DockPanel.Dock="Top"
                            Style="{StaticResource ThemButtonStyle}" />

                        <ItemsControl x:Name="PhonesItemsControl" ItemsSource="{Binding Phones}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2">
                                        <Button
                                            Margin="4,0,0,0"
                                            Click="DeletePhoneButton_Click"
                                            Content="✖"
                                            DockPanel.Dock="Right"
                                            Style="{StaticResource XoaButtonStyle}" />

                                        <CheckBox
                                            Margin="8,0,8,0"
                                            VerticalAlignment="Center"
                                            Checked="PhoneDefaultCheckBox_Checked"
                                            Content="Mặc định"
                                            IsChecked="{Binding IsDefault, Mode=TwoWay}" />

                                        <TextBox
                                            Width="160"
                                            VerticalAlignment="Center"
                                            Text="{Binding SoDienThoai, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </GroupBox>

                <GroupBox
                    Grid.Row="4"
                    Margin="0,0,0,6"
                    Header="Địa chỉ">
                    <DockPanel Margin="4">
                        <Button
                            x:Name="AddAddressButton"
                            Margin="0,0,0,4"
                            Padding="6,2"
                            HorizontalAlignment="Right"
                            Click="AddAddressButton_Click"
                            Content="+ Thêm địa chỉ"
                            DockPanel.Dock="Top"
                            Style="{StaticResource ThemButtonStyle}" />

                        <ItemsControl x:Name="AddressesItemsControl" ItemsSource="{Binding Addresses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2">
                                        <Button
                                            Margin="4,0,0,0"
                                            Click="DeleteAddressButton_Click"
                                            Content="✖"
                                            DockPanel.Dock="Right"
                                            Style="{StaticResource XoaButtonStyle}" />

                                        <CheckBox
                                            Margin="8,0,8,0"
                                            VerticalAlignment="Center"
                                            Checked="AddressDefaultCheckBox_Checked"
                                            Content="Mặc định"
                                            IsChecked="{Binding IsDefault, Mode=TwoWay}" />

                                        <TextBox
                                            Width="260"
                                            VerticalAlignment="Center"
                                            Text="{Binding DiaChi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </GroupBox>

                <TextBlock
                    x:Name="ErrorTextBlock"
                    Grid.Row="5"
                    Margin="0,8,0,6"
                    Style="{StaticResource ErrorTextBlock}" />

                <Button
                    Name="SaveButton"
                    Grid.Row="6"
                    Click="SaveButton_Click"
                    Content="Lưu"
                    Style="{StaticResource SaveButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Window>