<UserControl
    x:Class="TraSuaApp.WpfClient.Views.DoanhThuNamTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="Auto"
    Height="Auto">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
            <TextBlock
                Margin="0,0,5,0"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="Chọn năm:" />

            <ComboBox
                x:Name="cmbNam"
                Width="100"
                Margin="0,0,10,0" />

            <Button
                Width="80"
                Click="Reload_Click"
                Content="Tải lại" />
        </StackPanel>

        <!--  Data  -->
        <DataGrid
            x:Name="dataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Width="Auto"
                    Binding="{Binding Thang}"
                    Header="Tháng" />

                <DataGridTextColumn
                    Width="Auto"
                    Binding="{Binding SoDon}"
                    Header="Số đơn" />

                <DataGridTextColumn
                    Width="Auto"
                    Binding="{Binding TongTien, StringFormat=N0}"
                    Header="Doanh thu" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>