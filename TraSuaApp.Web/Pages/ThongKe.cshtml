@page
@model TraSuaAppWeb.Pages.ThongKeNgayModel
@{
    ViewData["Title"] = "Thống kê ngày";

    var ngay = Model.Ngay;
    var thang = Model.Thang;
    var nam = Model.Nam;

    var prev = new DateTime(nam, thang, ngay).AddDays(-1);
    var next = new DateTime(nam, thang, ngay).AddDays(1);
}

<div class="container-fluid mt-3">

<div class="d-flex justify-content-between align-items-center mb-3">
    <a class="btn btn-outline-primary"
       href="?ngay=@prev.Day&thang=@prev.Month&nam=@prev.Year">← Ngày trước</a>

    <div class="fw-bold">
        @ngay/@thang/@nam
    </div>

    <a class="btn btn-outline-primary"
       href="?ngay=@next.Day&thang=@next.Month&nam=@next.Year">Ngày sau →</a>
</div>

<div class="row g-3">

    <!-- THANH TOÁN -->
    <div class="col-md-4">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between">
                <span>Thanh toán</span>
                <span>@Model.TongThanhToan.ToString("N0")</span>
            </div>
            <div class="card-body">
                @foreach (var x in Model.ThanhToan)
                {
                    <div class="d-flex justify-content-between">
                        <span>@x.Ten</span>
                        <span>@x.SoTien.ToString("N0")</span>
                    </div>
                }
                <hr />
                <div class="d-flex justify-content-between">
                    <span>Chuyển khoản</span>
                    <span>@Model.ChuyenKhoan.ToString("N0")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- DOANH THU -->
    <div class="col-md-4">
        <div class="card border-success">
            <div class="card-header bg-success text-white d-flex justify-content-between">
                <span>Doanh thu</span>
                <span>@Model.TongDoanhThu.ToString("N0")</span>
            </div>
            <div class="card-body">
                @foreach (var x in Model.DoanhThu)
                {
                    <div class="d-flex justify-content-between">
                        <span>@x.Ten</span>
                        <span>@x.DoanhThu.ToString("N0")</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- CÔNG NỢ -->
    <div class="col-md-4" id="congno">
        <div class="card border-warning">
            <div class="card-header bg-warning d-flex justify-content-between">
                <span>Công nợ</span>
                <span>@Model.TongCongNo.ToString("N0")</span>
            </div>
            <div class="card-body">
                @foreach (var x in Model.CongNo)
                {
                    <div class="d-flex justify-content-between">
                        <span>@x.TenKhachHang</span>
                        <span>@x.SoTienNo.ToString("N0")</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- TRẢ NỢ -->
    <div class="col-md-4">
        <div class="card border-secondary">
            <div class="card-header bg-secondary text-white d-flex justify-content-between">
                <span>Trả nợ</span>
                <span>@Model.TongTraNo.ToString("N0")</span>
            </div>
            <div class="card-body">

                <div class="fw-bold">Tại quán</div>
                @foreach (var x in Model.TraNoTaiQuan)
                {
                    <div class="d-flex justify-content-between">
                        <span>@x.TenKhachHang</span>
                        <span>@x.SoTien.ToString("N0")</span>
                    </div>
                }

                <hr />

                <div class="fw-bold">Shipper</div>
                @foreach (var x in Model.TraNoShipper)
                {
                    <div class="d-flex justify-content-between">
                        <span>@x.TenKhachHang</span>
                        <span>@x.SoTien.ToString("N0")</span>
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- CHI TIÊU -->
    <div class="col-md-4" id="chitieu">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white d-flex justify-content-between">
                <span>Chi tiêu</span>
                <span>@Model.TongChiTieu.ToString("N0")</span>
            </div>
            <div class="card-body">

                <div class="fw-bold">Ngày</div>
                @foreach (var x in Model.ChiTieuNgay)
                {
                    <div class="d-flex justify-content-between">
                        <span>@x.Ten</span>
                        <span>@x.SoTien.ToString("N0")</span>
                    </div>
                }

                <hr />

                <div class="fw-bold">Tháng</div>
                @foreach (var x in Model.ChiTieuThang)
                {
                    <div class="d-flex justify-content-between">
                        <span>@x.Ten</span>
                        <span>@x.SoTien.ToString("N0")</span>
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- CHƯA THANH TOÁN -->
    <div class="col-md-4">
        <div class="card border-info">
            <div class="card-header bg-info text-white d-flex justify-content-between">
                <span>Chưa thanh toán</span>
                <span>@Model.TongChuaThanhToan.ToString("N0")</span>
            </div>
            <div class="card-body">
                @foreach (var x in Model.ChuaThanhToan)
                {
                    <div class="d-flex justify-content-between">
                        <span>@x.TenKhachHang</span>
                        <span>@x.SoTien.ToString("N0")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
</div>
<script>
    function showSpinner() {
        document.getElementById("globalSpinner")?.classList.add("show");
    }

    // bắt click tất cả link (a)
    document.querySelectorAll("a").forEach(a => {
        a.addEventListener("click", function () {
            showSpinner();
        });
    });

    // nếu có button submit (form)
    document.querySelectorAll("button").forEach(btn => {
        btn.addEventListener("click", function () {
            showSpinner();
        });
    });
</script>