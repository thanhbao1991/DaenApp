@page
@using TraSuaApp.Shared.Dtos
@model TraSuaAppWeb.Pages.ChiTietHoaDonNoTabModel
@{
    ViewData["Title"] = "Công Nợ Khách Hàng";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="container-fluid mt-3">

    <div class="d-flex justify-content-between mb-3">
        <h4><i class="fa fa-money-bill-wave text-success"></i> Công Nợ</h4>
    </div>

    <!-- SEARCH -->
    <div class="input-group mb-3">
        <input id="searchBox" class="form-control" placeholder="Tìm kiếm..." />
    </div>

    <!-- TABLE -->
    <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Ngày</th>
                    <th>Giờ</th>
                    <th>Tên</th>
                    <th class="text-end">Còn lại</th>
                    <th>Ghi chú</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="tbody"></tbody>
        </table>
    </div>

    <div class="text-end mt-2">
        <b>Tổng:</b>
        <span id="totalDebt" class="text-danger fw-bold"></span>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="payModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Thanh toán</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="m_id" />
                <input type="hidden" id="m_type" />

                <div class="mb-2">
                    <label>Khách</label>
                    <input id="m_name" class="form-control" readonly />
                </div>

                <div class="mb-2">
                    <label>Số tiền</label>
                    <input id="m_amount" class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Ghi chú</label>
                    <textarea id="m_note" class="form-control"></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button class="btn btn-primary" onclick="submitModal()">Lưu</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>

        let items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items ?? new List<TraSuaApp.Shared.Dtos.HoaDonNoDto>()));
        let debounceTimer;

        // =====================
        // RENDER
        // =====================
        function render() {

            let tbody = document.getElementById("tbody");
            tbody.innerHTML = "";

            let total = 0;
            let stt = 1;

            items.forEach(x => {

                if (x._hidden) return;

                total += x.ConLai;

                tbody.innerHTML += `
                <tr>
                    <td class="text-center">${stt++}</td>
                    <td class="text-center">${formatDate(x.NgayGio)}</td>
                    <td class="text-center">${formatTime(x.NgayGio)}</td>
                    <td>${x.TenKhachHangText ?? ""}</td>
                    <td class="text-end text-danger fw-bold">${money(x.ConLai)}</td>
                    <td>${x.GhiChu ?? ""}</td>
                    <td>
                        <button class="btn btn-sm btn-success" data-type="TienMat" onclick="handleClick(event,'${x.Id}')">TM</button>
                        <button class="btn btn-sm btn-primary" data-type="ChuyenKhoan" onclick="handleClick(event,'${x.Id}')">CK</button>
                    </td>
                </tr>`;
            });

            document.getElementById("totalDebt").innerText = money(total);
        }

        // =====================
        // SEARCH
        // =====================
        document.getElementById("searchBox").addEventListener("input", e => {

            clearTimeout(debounceTimer);

            debounceTimer = setTimeout(() => {
                let key = normalize(e.target.value);

                items.forEach(x => {
                    let text = normalize(x.TimKiem || "");
                    x._hidden = !text.includes(key);
                });

                render();
            }, 300);
        });

        // =====================
        // CLICK
        // =====================
        function handleClick(ev, id) {

            let type = ev.currentTarget.dataset.type;

            if (ev.ctrlKey) {
                pay(id, type, true);
                return;
            }

            openModal(id, type);
        }

        // =====================
        // MODAL
        // =====================
        function openModal(id, type) {

            let item = items.find(x => x.Id === id);

            document.getElementById("m_id").value = id;
            document.getElementById("m_type").value = type;
            document.getElementById("m_name").value = item.TenKhachHangText;
            document.getElementById("m_amount").value = item.ConLai;
            document.getElementById("m_note").value = item.GhiChu ?? "";

            new bootstrap.Modal(document.getElementById('payModal')).show();
        }

        async function submitModal() {

            let id = m_id.value;
            let type = m_type.value;
            let amount = parseFloat(m_amount.value || "0");
            let note = m_note.value;

            await pay(id, type, false, amount, note);

            bootstrap.Modal.getInstance(document.getElementById('payModal')).hide();
        }

        // =====================
        // CORE LOGIC
        // =====================
        async function pay(id, type, quick = false, amount = null, note = null) {

            let item = items.find(x => x.Id === id);
            if (!item) return;

            if (item.ConLai <= 0) {
                alert("Đã thu đủ");
                return;
            }

            if (quick)
                amount = item.ConLai;

            // backup
            let old = { ...item };

            // optimistic UI
            item.DaThu += amount;
            item.ConLai = item.ThanhTien - item.DaThu;

            if (item.ConLai <= 0)
                items = items.filter(x => x.Id !== id);

            render();

            try {

                let res = await fetch('?handler=Pay', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, type, amount, note })
                });

                let r = await res.json();

                if (!r.success) throw "fail";

            } catch {

                Object.assign(item, old);
                if (!items.find(x => x.Id === item.Id))
                    items.push(item);

                render();

                alert("Thanh toán lỗi");
            }
        }

        // =====================
        // HELPERS
        // =====================
        function normalize(str) {
            return (str || "").toLowerCase()
                .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        }

        function money(x) {
            return (x || 0).toLocaleString('vi-VN') + " đ";
        }

        function formatDate(d) {
            if (!d) return "";
            return new Date(d).toLocaleDateString('vi-VN');
        }

        function formatTime(d) {
            if (!d) return "";
            return new Date(d).toLocaleTimeString('vi-VN');
        }

        // init
        render();

    </script>
}