@page
@using TraSuaApp.Shared.Dtos
@model TraSuaAppWeb.Pages.ChiTietHoaDonNoTabModel
@{
    ViewData["Title"] = "Công Nợ Khách Hàng";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="container-fluid mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">
            <i class="fa fa-money-bill-wave text-success"></i> Công Nợ
        </h4>
    </div>

    <div class="input-group mb-3">
        <span class="input-group-text bg-white border-0 shadow-sm">
            <i class="fa fa-search text-muted"></i>
        </span>
        <input class="form-control shadow-sm border-0"
               style="border-radius:12px"
               placeholder="Tìm kiếm khách hàng / ghi chú..."
               oninput="onSearch(this.value)" />
    </div>

    <div id="cardContainer" class="row g-3"></div>

    <div class="text-end mt-3">
        <b>Tổng:</b>
        <span id="totalDebt" class="text-danger fw-bold"></span>
    </div>
</div>

@section Scripts {
    <script>
        let items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items ?? new List<TraSuaApp.Shared.Dtos.HoaDonNoDto>()));

        let swipe = {};
        let swipeConfirm = {};

        function onSearch(key){
            key = (key||"").toLowerCase();

            items.forEach(x=>{
                x._hidden =
                    !(x.TenKhachHangText||"").toLowerCase().includes(key) &&
                    !(x.GhiChu||"").toLowerCase().includes(key);
            });

            render();
        }

        function render(){
            let container = document.getElementById("cardContainer");
            container.innerHTML = "";

            let total = 0;

            items.forEach(x=>{
                if(x._hidden) return;

                total += (x.ConLai || 0);

                let type = swipeConfirm[x.Id]?.type;

                let dimClass = "";
                if(type === "ChuyenKhoan") dimClass = "dim-blue";
                if(type === "TienMat") dimClass = "dim-green";

                container.innerHTML += `
                <div class="col-12 col-md-6 col-xl-4">

                    <div class="debt-card ${dimClass}"
                         data-id="${x.Id}"
                         onpointerdown="startSwipe(event,'${x.Id}')"
                         onpointermove="moveSwipe(event,'${x.Id}')"
                         onpointerup="endSwipe(event,'${x.Id}')"
                         onpointercancel="cancelSwipe(event)">

                        <div class="card-inner">

                            <div class="top-row">

                                <div class="avatar">
                                    ${getInitials(x.TenKhachHangText)}
                                </div>

                                <div class="info">
                                    <div class="name">
                                        ${x.TenKhachHangText ?? "Khách lẻ"}
                                    </div>
                                    <div class="time">
                                        <i class="fa fa-clock me-1"></i>
                                        ${formatDate(x.NgayGio)}
                                    </div>
                                </div>

                                <div class="amount">
                                    ${money(x.ConLai)}
                                </div>

                            </div>

                            <div class="note">
                                ${x.GhiChu ?? ""}
                            </div>

                        </div>
                    </div>
                </div>`;
            });

            document.getElementById("totalDebt").innerText = money(total);
        }

        // ================= SWIPE =================
        function startSwipe(ev,id){
            swipe = { id, x: ev.clientX };
        }

        function moveSwipe(ev,id){
            if(!swipe.id || swipe.id !== id) return;

            let dx = ev.clientX - swipe.x;
            let el = ev.currentTarget;

            el.style.transform = `translateX(${dx}px)`;

            el.style.background = dx > 0
                ? "linear-gradient(135deg,#3b82f6,#2563eb)"
                : "linear-gradient(135deg,#22c55e,#16a34a)";
        }

        function endSwipe(ev,id){
            let el = ev.currentTarget;

            let dx = ev.clientX - swipe.x;

            el.style.transform = "";
            el.style.background = "";

            if(Math.abs(dx) < 80){
                swipe = {};
                return;
            }

            let type = dx > 0 ? "ChuyenKhoan" : "TienMat";
            let item = items.find(x => x.Id === id);
            let amount = item?.ConLai || 0;

            // ================= LẦN 1 =================
            if(!swipeConfirm[id]){
                swipeConfirm[id] = { type, amount };
                showConfirmOverlay(id);
                swipe = {};
                return;
            }

            // ================= LẦN 2 (đổi hướng) =================
            if(swipeConfirm[id].type !== type){
                swipeConfirm[id] = { type, amount };
                showConfirmOverlay(id);
                swipe = {};
                return;
            }

            // ================= LẦN 2 OK =================
            delete swipeConfirm[id];
            removeOverlay(id);

            quickPay(id,type);

            swipe = {};
        }

        function cancelSwipe(ev){
            ev.currentTarget.style.transform = "";
            ev.currentTarget.style.background = "";
            swipe = {};
        }

        // ================= OVERLAY =================
        function showConfirmOverlay(id){

            let card = document.querySelector(`[data-id="${id}"]`);
            if(!card) return;

            let data = swipeConfirm[id];
            if(!data) return;

            let label = data.type === "ChuyenKhoan"
                ? "CHUYỂN KHOẢN"
                : "TIỀN MẶT";

            let overlayId = "overlay-" + id;
            document.getElementById(overlayId)?.remove();

            let div = document.createElement("div");
            div.id = overlayId;
            div.className = "overlay";

            div.style.background =
                data.type === "ChuyenKhoan"
                    ? "rgba(59,130,246,0.75)"
                    : "rgba(34,197,94,0.75)";

            div.innerHTML = `
                <div class="money">${money(data.amount)}</div>
                <div class="label">${label}</div>
            `;

            card.style.position = "relative";
            card.appendChild(div);
        }

        function removeOverlay(id){
            document.getElementById("overlay-" + id)?.remove();
            delete swipeConfirm[id];
        }

        // ================= PAYMENT =================
        async function quickPay(id,type){
            let item = items.find(x=>x.Id===id);
            if(!item) return;

            await pay(id,type,item.ConLai,item.KhachHangId,item.TenKhachHangText);
        }


        async function pay(id,type,amount,khachHangId,ten){

            amount = parseFloat(amount || 0);
            if(amount <= 0) return;

            let old = [...items];
            let itemIndex = items.findIndex(x => x.Id === id);
            let item = items[itemIndex];

            if(!item) return;

            item.DaThu = (item.DaThu || 0) + amount;
            item.ConLai = (item.ThanhTien || 0) - item.DaThu;

            render();

            let phuongThuc =
                type === "ChuyenKhoan"
                    ? "2CF9A88F-3BC0-4D4B-940D-F8FFA4AFFA02"
                    : "0121FC04-0469-4908-8B9A-7002F860FB5C";

            try{
                let res = await fetch('?handler=Pay',{
                    method:'POST',
                    headers:{'Content-Type':'application/json'},
                    body: JSON.stringify({
                        id,
                        khachHangId,
                        ten,
                        soTien: amount,
                        phuongThucThanhToanId: phuongThuc
                    })
                });

                let r = await res.json();
                if(!r.isSuccess) throw "";

                // 🟟 CHỈ SỬA PHẦN NÀY: XÓA ITEM SAU KHI PAY THÀNH CÔNG
                items.splice(itemIndex, 1);

                // reset swipe state
                swipe = {};
                delete swipeConfirm[id];

                // render lại để item tiếp theo nhảy lên
                render();

            }catch{
                items = old;
                render();
            }
        }

        // ================= UTILS =================
        function money(x){return (x||0).toLocaleString('vi-VN')+" đ";}
        function formatDate(d){return d?new Date(d).toLocaleString('vi-VN'):"";}
        function getInitials(name){
            if(!name) return "?";
            return name.split(" ").slice(-2).map(x=>x[0]).join("").toUpperCase();
        }

        render();
    </script>
}

<style>
    .debt-card {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        transition: .2s;
        user-select: none;
        touch-action: pan-y;
    }

        .debt-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 35px rgba(0,0,0,.12);
        }

    /* ================= DIM STATES ================= */
    .dim-blue {
        position: relative;
    }

    .dim-green {
        position: relative;
    }

    .dim-blue::after {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(59,130,246,0.18); /* 🟟 xanh dương đậm hơn */
        pointer-events: none;
    }

    .dim-green::after {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(34,197,94,0.18); /* 🟟 xanh lá đậm hơn */
        pointer-events: none;
    }

    /* ================= CONTENT ================= */
    .card-inner {
        padding: 16px;
    }

    .top-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
    }

    .avatar {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg,#3b82f6,#60a5fa);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .amount {
        font-weight: 800;
        color: #ef4444;
    }

    /* ================= OVERLAY ================= */
    .overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        font-weight: 800;
        text-align: center;
        z-index: 10;
    }

        .overlay .money {
            font-size: 22px;
        }

        .overlay .label {
            margin-top: 6px;
        }

        .overlay .hint {
            margin-top: 10px;
            font-size: 12px;
            opacity: .9;
        }
</style>