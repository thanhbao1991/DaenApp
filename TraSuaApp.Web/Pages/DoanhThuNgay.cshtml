@page
@using TraSuaApp.Shared.Dtos
@model TraSuaAppWeb.Pages.DoanhThuNgayModel

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

@{
    var currentDate = new DateTime(Model.Nam, Model.Thang, Model.Ngay);
    var prev = currentDate.AddDays(-1);
    var next = currentDate.AddDays(1);
}

<div class="container-fluid mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <a class="btn btn-outline-primary"
           href="?Ngay=@prev.Day&Thang=@prev.Month&Nam=@prev.Year">
            ← Ngày trước
        </a>

        <div class="fw-bold fs-5 text-center">
            @Model.Ngay/@Model.Thang/@Model.Nam
        </div>

        <a class="btn btn-outline-primary"
           href="?Ngay=@next.Day&Thang=@next.Month&Nam=@next.Year">
            Ngày sau →
        </a>
    </div>

    <div class="mb-3">
        <input id="searchBox" class="form-control"
               placeholder="Tìm khách hàng / ghi chú..."
               oninput="render()" />
    </div>

    <div id="cardContainer" class="row g-3"></div>

</div>

@section Scripts {
    <script>

        let items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items));

        let swipe = {};
        let swipeConfirm = {};
        let noteToggle = {};
        let f12Confirm = {};
        let pressState = {};

        function getPressState(id) {
            if (!pressState[id]) {
                pressState[id] = {
                    timer: null,
                    startX: 0,
                    startY: 0,
                    moved: false,
                    longPressed: false,
                    suppressClick: false
                };
            }
            return pressState[id];
        }

        function render() {

            let keyword = document.getElementById("searchBox")?.value?.toLowerCase() || "";

            let filtered = items.filter(x =>
                (x.TenKhachHangText || "").toLowerCase().includes(keyword) ||
                (x.GhiChu || "").toLowerCase().includes(keyword)
            );

            filtered.sort((a, b) => {
                let aTop = a.ConLai > 0 && !a.NgayNo;
                let bTop = b.ConLai > 0 && !b.NgayNo;

                if (aTop && !bTop) return -1;
                if (!aTop && bTop) return 1;

                return new Date(b.NgayGio) - new Date(a.NgayGio);
            });

            let container = document.getElementById("cardContainer");
            container.innerHTML = "";

            filtered.forEach(x => {

                let colorClass = "";

                if (x.NgayNo) colorClass = "card-red";
                else if (x.IsBank) colorClass = "card-blue";
                else if (x.ConLai === 0 && !x.IsBank) colorClass = "card-green";

                let type = getType(x);

                let dimClass = "";
                let confirm = swipeConfirm[x.Id];

                if (confirm?.type === "ChuyenKhoan") dimClass = "dim-blue";
                if (confirm?.type === "TienMat") dimClass = "dim-green";

                let showNote = !!noteToggle[x.Id];

                container.innerHTML += `
                <div class="col-12 col-md-6 col-xl-4">

                    <div class="debt-card ${colorClass} ${dimClass}"
                         data-id="${x.Id}"
                         onclick="handleCardClick(event,'${x.Id}')"
                         onpointerdown="handlePointerDown(event,'${x.Id}')"
                         onpointermove="handlePointerMove(event,'${x.Id}')"
                         onpointerup="handlePointerUp(event,'${x.Id}')"
                         onpointercancel="cancelInteraction(event,'${x.Id}')"
                         onpointerleave="cancelInteraction(event,'${x.Id}')">

                        <div class="card-inner">

                            <div class="top-row">

                                <div class="avatar">
                                    ${type}
                                </div>

                                <div class="info">
                                    <div class="time" id="time-${x.Id}">
                                        <i class="fa fa-clock me-1"></i>
                                        ${renderTime(x)}
                                    </div>
                                    <div class="name">
                                        ${x.TenKhachHangText ?? "Khách lẻ"}
                                    </div>
                                </div>

                                <div class="amount">
                                    ${money(x.ThanhTien)}
                                </div>

                            </div>

                            ${showNote ? `
                            <div class="note">
                                ${x.GhiChu ?? ""}
                            </div>` : ""}

                        </div>
                    </div>
                </div>`;
            });

            if (filtered.length === 0) {
                container.innerHTML = `
                    <div class="col-12">
                        <div class="alert alert-light text-center">
                            Không có dữ liệu
                        </div>
                    </div>
                `;
            }

            restoreOverlays();
        }

        function restoreOverlays() {
            Object.keys(swipeConfirm).forEach(id => {
                showPaymentOverlay(id);
            });

            Object.keys(f12Confirm).forEach(id => {
                showDebtOverlay(id);
            });
        }

        function handleCardClick(ev, id) {
            let state = getPressState(id);

            if (state.suppressClick) {
                state.suppressClick = false;
                return;
            }

            if (state.longPressed) {
                state.longPressed = false;
                return;
            }

            toggleNote(id);
        }

        function toggleNote(id) {
            noteToggle[id] = !noteToggle[id];
            render();
        }

        function handlePointerDown(ev, id) {
            let state = getPressState(id);

            state.startX = ev.clientX;
            state.startY = ev.clientY;
            state.moved = false;
            state.longPressed = false;
            state.suppressClick = false;

            swipe = { id, x: ev.clientX };

            clearTimeout(state.timer);
            state.timer = setTimeout(() => {
                state.longPressed = true;
                state.suppressClick = true;
                triggerLongPress(id);
            }, 550);
        }

        function handlePointerMove(ev, id) {
            let state = getPressState(id);

            if (!swipe.id || swipe.id !== id) return;

            let dx = ev.clientX - swipe.x;
            let dy = ev.clientY - state.startY;

            if (Math.abs(dx) > 10 || Math.abs(dy) > 10) {
                state.moved = true;
                clearTimeout(state.timer);
            }

            let el = ev.currentTarget;
            el.style.transform = `translateX(${dx}px)`;
            el.style.background = dx > 0
                ? "linear-gradient(135deg,#3b82f6,#2563eb)"
                : "linear-gradient(135deg,#22c55e,#16a34a)";
        }

        function handlePointerUp(ev, id) {
            let state = getPressState(id);
            clearTimeout(state.timer);

            let el = ev.currentTarget;
            let dx = ev.clientX - swipe.x;

            el.style.transform = "";
            el.style.background = "";

            if (state.longPressed) {
                state.suppressClick = true;
                swipe = {};
                return;
            }

            if (Math.abs(dx) < 80) {
                swipe = {};
                return;
            }

            let type = dx > 0 ? "ChuyenKhoan" : "TienMat";
            let item = items.find(x => x.Id === id);
            let amount = item?.ConLai || 0;

            state.suppressClick = true;

            if (!swipeConfirm[id]) {
                swipeConfirm[id] = { type, amount };
                removeDebtOverlay(id);
                showPaymentOverlay(id);
                swipe = {};
                return;
            }

            if (swipeConfirm[id].type !== type) {
                swipeConfirm[id] = { type, amount };
                removePaymentOverlay(id);
                showPaymentOverlay(id);
                swipe = {};
                return;
            }

            delete swipeConfirm[id];
            removePaymentOverlay(id);

            quickPay(id, type);

            swipe = {};
        }

        function cancelInteraction(ev, id) {
            clearLongPressTimer(id);

            ev.currentTarget.style.transform = "";
            ev.currentTarget.style.background = "";
            swipe = {};
        }

        function clearLongPressTimer(id) {
            let state = getPressState(id);
            clearTimeout(state.timer);
            state.timer = null;
        }

        function triggerLongPress(id) {
            let item = items.find(x => x.Id === id);
            if (!item) return;

            delete swipeConfirm[id];
            removePaymentOverlay(id);

            if (!f12Confirm[id]) {
                f12Confirm[id] = { amount: item.ConLai || 0 };
                showDebtOverlay(id);
                return;
            }

            delete f12Confirm[id];
            removeDebtOverlay(id);

            callF12(id, item);
        }

        function showPaymentOverlay(id) {
            let card = document.querySelector(`[data-id="${id}"]`);
            if (!card) return;

            let data = swipeConfirm[id];
            if (!data) return;

            card.querySelector(".overlay.payment-overlay")?.remove();

            let label = data.type === "ChuyenKhoan"
                ? "CHUYỂN KHOẢN"
                : "TIỀN MẶT";

            let div = document.createElement("div");
            div.className = "overlay payment-overlay";

            div.style.background =
                data.type === "ChuyenKhoan"
                    ? "rgba(59,130,246,0.75)"
                    : "rgba(34,197,94,0.75)";

            div.innerHTML = `
                <div class="money">${money(data.amount)}</div>
                <div>${label}</div>
            `;

            card.appendChild(div);
        }

        function removePaymentOverlay(id) {
            document.querySelector(`[data-id="${id}"] .overlay.payment-overlay`)?.remove();
        }

        function showDebtOverlay(id) {
            let card = document.querySelector(`[data-id="${id}"]`);
            if (!card) return;

            let data = f12Confirm[id];
            if (!data) return;

            card.querySelector(".overlay.debt-overlay")?.remove();

            let div = document.createElement("div");
            div.className = "overlay debt-overlay";

            div.innerHTML = `
                <div class="money">${money(data.amount)}</div>
                <div>GHI NỢ</div>
                <div class="small mt-1">Nhấn giữ lần nữa để xác nhận</div>
            `;

            card.appendChild(div);
        }

        function removeDebtOverlay(id) {
            document.querySelector(`[data-id="${id}"] .overlay.debt-overlay`)?.remove();
        }

        function getType(x) {
            let p = (x.PhanLoai || "");

            if (p.includes("App")) return "APP";
            if (p.includes("Ship")) return "SHI";
            if (p.includes("Mv")) return "MVE";
            if (p.includes("Tại Chỗ")) return "TC";
            return "?";
        }

        function renderTime(x) {
            let now = new Date();
            let time = new Date(x.NgayGio);

            if (x.ConLai > 0 && !x.NgayNo) {
                let diff = Math.floor((now - time) / 1000);

                let h = Math.floor(diff / 3600);
                let m = Math.floor((diff % 3600) / 60);

                if (h > 0) return `${h}h ${m}p`;
                return `${m}p`;
            }

            return time.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
        }

        function updateTime() {
            items.forEach(x => {
                let el = document.getElementById(`time-${x.Id}`);
                if (!el) return;

                el.innerHTML = `<i class="fa fa-clock me-1"></i> ${renderTime(x)}`;
            });
        }

        async function quickPay(id, type) {
            let item = items.find(x => x.Id === id);
            if (!item) return;

            let amount = item.ConLai || 0;

            let phuongThuc =
                type === "ChuyenKhoan"
                    ? "2CF9A88F-3BC0-4D4B-940D-F8FFA4AFFA02"
                    : "0121FC04-0469-4908-8B9A-7002F860FB5C";

            try {
                let res = await fetch('?handler=Pay', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id,
                        khachHangId: item.KhachHangId,
                        ten: item.TenKhachHangText,
                        soTien: amount,
                        phuongThucThanhToanId: phuongThuc
                    })
                });

                let r = await res.json();
                if (!r.isSuccess) throw "";

                items = items.filter(x => x.Id !== id);
                render();

            } catch {
                alert("Thanh toán thất bại");
            }
        }

        async function callF12(id, item) {
            try {
                let res = await fetch('?handler=F12', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id,
                        dto: item
                    })
                });

                let r = await res.json();
                if (!r.isSuccess) throw "";

                let local = items.find(x => x.Id === id);
                if (local) {
                    local.NgayNo = local.NgayNo || new Date().toISOString();
                }

                render();

            } catch {
                alert("Ghi nợ thất bại");
            }
        }

        function money(x) {
            return (x || 0).toLocaleString('vi-VN') + " đ";
        }

        render();
        setInterval(updateTime, 1000);

    </script>
}

<style>
    .debt-card {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        transition: .2s;
        touch-action: pan-y;
        user-select: none;
    }

        .debt-card:hover {
            transform: translateY(-2px);
        }

    .card-inner {
        padding: 16px;
    }

    .top-row {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .avatar {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg,#3b82f6,#60a5fa);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
    }

    .info {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        min-width: 0;
    }

    .name {
        width: 100%;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .time {
        width: 100%;
        font-size: 13px;
        opacity: 0.7;
    }

    .amount {
        font-weight: 800;
        color: #ef4444;
        flex-shrink: 0;
    }

    .note {
        margin-top: 10px;
        font-size: 13px;
        opacity: .85;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        font-weight: 800;
        z-index: 10;
        backdrop-filter: blur(2px);
        pointer-events: none;
    }

        .overlay .money {
            font-size: 1.15rem;
        }

    .card-red {
        background: linear-gradient(135deg,#fee2e2,#fecaca);
    }

    .card-blue {
        background: linear-gradient(135deg,#dbeafe,#bfdbfe);
    }

    .card-green {
        background: linear-gradient(135deg,#dcfce7,#bbf7d0);
    }

    .dim-blue {
        opacity: .6;
    }

    .dim-green {
        opacity: .6;
    }

    .debt-overlay {
        background: rgba(239,68,68,0.85);
    }
</style>