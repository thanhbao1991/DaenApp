@page
@using TraSuaApp.Shared.Dtos
@model TraSuaAppWeb.Pages.DoanhThuNgayModel

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

@{
    var currentDate = new DateTime(Model.Nam, Model.Thang, Model.Ngay);
    var prev = currentDate.AddDays(-1);
    var next = currentDate.AddDays(1);
}

<div class="container-fluid mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <a class="btn btn-outline-primary"
           href="?Ngay=@prev.Day&Thang=@prev.Month&Nam=@prev.Year">
            ← Ngày trước
        </a>

        <div class="fw-bold">
            @Model.Ngay/@Model.Thang/@Model.Nam
        </div>

        <a class="btn btn-outline-primary"
           href="?Ngay=@next.Day&Thang=@next.Month&Nam=@next.Year">
            Ngày sau →
        </a>
    </div>

    <div class="mb-3 d-flex align-items-center gap-2">
        <input id="searchBox"
               class="form-control"
               style="max-width: 70%;"
               placeholder="Tìm..."
               oninput="render()" />

        <div id="totalMoney"
             class="fw-bold fs-5 text-danger ms-auto text-end"
             style="min-width: 120px;">
            0 đ
        </div>
    </div>

    <div id="cardContainer" class="row g-3"></div>
</div>

@section Scripts {
    <script>
        let items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items));

        let noteToggle = {};
        let detailCache = {};
        let cardState = {};
        let swipeState = {};
        let openCardId = null;
        let clickBlock = {};

        const BUTTON_WIDTH = 70;
        const TOTAL_BUTTONS = 5;
        const REVEAL_WIDTH = BUTTON_WIDTH * TOTAL_BUTTONS;
        const OPEN_THRESHOLD = 60;
        const DRAG_THRESHOLD = 8;

        function money(x) {
            return (x || 0).toLocaleString('vi-VN') + " đ";
        }

        function getProp(obj, name, fallback = "") {
            if (!obj) return fallback;
            if (obj[name] !== undefined && obj[name] !== null) return obj[name];
            const pascal = name.charAt(0).toUpperCase() + name.slice(1);
            if (obj[pascal] !== undefined && obj[pascal] !== null) return obj[pascal];
            return fallback;
        }

        function firstNonEmpty(...values) {
            for (const v of values) {
                if (v !== undefined && v !== null && String(v).trim() !== "") return v;
            }
            return "";
        }

        function getType(x) {
            let p = (x.PhanLoai || x.phanLoai || "");
            if (p.includes("App")) return "APP";
            if (p.includes("Ship")) return "SHI";
            if (p.includes("Mv")) return "MVE";
            if (p.includes("Tại Chỗ")) return "TC";
            return "?";
        }

        function getAvatarIcon(type, x) {
            if (type === "SHI") {
                if ((x?.NguoiShip || x?.nguoiShip) === "Nhã") return `<img src="/images/nha.jpg" class="avatar-img" />`;
                if ((x?.NguoiShip || x?.nguoiShip) === "Khánh") return `<img src="/images/khanh.jpg" class="avatar-img" />`;
                return `<img src="/images/ship.jpg" class="avatar-img" />`;
            }
            switch (type) {
                case "APP": return `<img src="/images/app.jpg" class="avatar-img" />`;
                case "MVE": return `<img src="/images/muave.jpg" class="avatar-img" />`;
                case "TC":  return `<img src="/images/taicho.jpg" class="avatar-img" />`;
                default:    return `<i class="fa-solid fa-question"></i>`;
            }
        }

        function renderTime(x) {
            let now  = new Date();
            let time = new Date(x.NgayGio || x.ngayGio);
            if ((x.ConLai ?? x.conLai) > 0 && !(x.NgayNo ?? x.ngayNo)) {
                let diff = Math.floor((now - time) / 1000);
                let h = Math.floor(diff / 3600);
                let m = Math.floor((diff % 3600) / 60);
                if (h > 0) return `${h}h ${m}p`;
                return `${m}p`;
            }
            return time.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
        }

        function getCardEl(id) {
            return document.querySelector(`[data-id="${id}"]`);
        }

        function setCardOffset(id, offset) {
            cardState[id] = offset;
            let el = getCardEl(id);
            if (el) el.style.transform = `translateX(${offset}px)`;
        }

        function closeCard(id) {
            if (!id) return;
            setCardOffset(id, 0);
            if (openCardId === id) openCardId = null;
        }

        function applyCardStates() {
            Object.keys(cardState).forEach(id => {
                let el = getCardEl(id);
                if (!el) return;
                el.style.transform = `translateX(${cardState[id] || 0}px)`;
            });
        }

        function insertDetail(id) {
            let card = getCardEl(id);
            if (!card) return;
            let old = card.querySelector(".detail-box");
            if (old) old.remove();
            let inner = card.querySelector(".card-inner");
            if (!inner) return;
            let tmp = document.createElement("div");
            tmp.innerHTML = renderDetail(id);
            let box = tmp.firstElementChild;
            if (box) inner.appendChild(box);
        }

        async function handleCardClick(ev, id) {
            if (clickBlock[id]) {
                delete clickBlock[id];
                return;
            }
            let state = swipeState[id];
            if (state?.dragging) return;

            if (noteToggle[id]) {
                noteToggle[id] = false;
                let card = getCardEl(id);
                let box = card?.querySelector(".detail-box");
                if (box) box.remove();
                return;
            }

            noteToggle[id] = true;

            if (detailCache[id] === undefined) {
                detailCache[id] = null;
                insertDetail(id);
                await loadDetail(id);
                return;
            }

            insertDetail(id);
        }

        async function loadDetail(id) {
            try {
                let res = await fetch(`?handler=Detail&id=${id}`);
                if (!res.ok) {
                    detailCache[id] = { error: true };
                } else {
                    let r = await res.json();
                    detailCache[id] = r.isSuccess ? r.data : { error: true };
                }
            } catch {
                detailCache[id] = { error: true };
            }
            if (noteToggle[id]) insertDetail(id);
        }

        function render() {
            let keyword = document.getElementById("searchBox")?.value?.toLowerCase() || "";

            let filtered = items.filter(x =>
                (x.TenKhachHangText || x.tenKhachHangText || x.TenBan || x.tenBan || "").toLowerCase().includes(keyword) ||
                (x.GhiChu || x.ghiChu || "").toLowerCase().includes(keyword)
            );

            filtered.sort((a, b) => {
                let aTop = (a.ConLai ?? a.conLai) > 0 && !(a.NgayNo ?? a.ngayNo);
                let bTop = (b.ConLai ?? b.conLai) > 0 && !(b.NgayNo ?? b.ngayNo);
                if (aTop && !bTop) return -1;
                if (!aTop && bTop) return 1;
                return new Date(b.NgayGio || b.ngayGio) - new Date(a.NgayGio || a.ngayGio);
            });

            let visibleIds = new Set(filtered.map(x => x.Id || x.id));
            if (openCardId && !visibleIds.has(openCardId)) openCardId = null;
            Object.keys(cardState).forEach(id => { if (!visibleIds.has(id)) delete cardState[id]; });

            let container = document.getElementById("cardContainer");
            container.innerHTML = "";

            filtered.forEach(x => {
                let id = x.Id || x.id;
                let colorClass = "";
                if (x.NgayNo || x.ngayNo) colorClass = "card-red";
                else if (x.IsBank || x.isBank) colorClass = "card-blue";
                else if (((x.ConLai ?? x.conLai) === 0) && !(x.IsBank || x.isBank)) colorClass = "card-green";

                let type = getType(x);
                let showDetail = !!noteToggle[id];
                let ten = firstNonEmpty(x.TenKhachHangText, x.tenKhachHangText, x.TenBan, x.tenBan, "Khách lẻ");

                container.innerHTML += `
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="swipe-wrapper"
                             onpointerdown="handleSwipeStart(event, '${id}')"
                             onpointermove="handleSwipeMove(event, '${id}')"
                             onpointerup="handleSwipeEnd(event, '${id}')"
                             onpointercancel="handleSwipeCancel(event, '${id}')">

                            <div class="actions right">
                                <button type="button" class="btn-esc" onclick="onAction('${id}','ESC'); event.stopPropagation();">
                                    <img src="/images/khanh.jpg" alt="ESC" />
                                </button>
                                <button type="button" class="btn-esc2" onclick="onAction('${id}','ESC2'); event.stopPropagation();">
                                    <img src="/images/nha.jpg" alt="ESC2" />
                                </button>
                                <button type="button" class="btn-cash" onclick="confirmAction('${id}','Z'); event.stopPropagation();">
                                    <img src="/images/tienmat.jpg" alt="Tiền mặt" />
                                </button>
                                <button type="button" class="btn-bank" onclick="confirmAction('${id}','A'); event.stopPropagation();">
                                    <img src="/images/chuyenkhoan.jpg" alt="Chuyển khoản" />
                                </button>
                                <button type="button" class="btn-debt" onclick="confirmAction('${id}','B'); event.stopPropagation();">
                                    <img src="/images/ghino.jpg" alt="Ghi nợ" />
                                </button>
                            </div>

                            <div class="debt-card ${colorClass}"
                                 data-id="${id}"
                                 onclick="handleCardClick(event, '${id}')">
                                <div class="card-inner">
                                    <div class="top-row">
                                        <div class="avatar">${getAvatarIcon(type, x)}</div>
                                        <div class="info">
                                            <div class="time" id="time-${id}">
                                                <i class="fa fa-clock me-1"></i>${renderTime(x)}
                                            </div>
                                            <div class="name">${ten}</div>
                                        </div>
                                        <div class="amount">${money(x.ThanhTien ?? x.thanhTien)}</div>
                                    </div>
                                    ${showDetail ? renderDetail(id) : ""}
                                </div>
                            </div>
                        </div>
                    </div>`;
            });

            if (filtered.length === 0) {
                container.innerHTML = `
                    <div class="col-12">
                        <div class="alert alert-light text-center">Không có dữ liệu</div>
                    </div>`;
            }

            let total = filtered.reduce((sum, x) => sum + (x.ThanhTien ?? x.thanhTien ?? 0), 0);
            document.getElementById("totalMoney").innerText = money(total);
            applyCardStates();
        }

        function renderDetail(id) {
            let d = detailCache[id];

            if (d === undefined || d === null) {
                return `<div class="detail-box"><div class="note text-muted">⏳ Đang tải...</div></div>`;
            }
            if (d.error) {
                return `<div class="detail-box"><div class="note text-danger">Lỗi tải dữ liệu</div></div>`;
            }

            const ten            = firstNonEmpty(getProp(d, "tenKhachHangText"), getProp(d, "tenKhachHang"), getProp(d, "tenBan"), "Khách lẻ");
            const diaChi         = firstNonEmpty(getProp(d, "diaChiText"), getProp(d, "diaChi"), "");
            const sdt            = firstNonEmpty(getProp(d, "soDienThoaiText"), getProp(d, "soDienThoai"), "");
            const ghiChu         = firstNonEmpty(getProp(d, "ghiChu"), "");
            const ghiChuShipper  = firstNonEmpty(getProp(d, "ghiChuShipper"), "");
            const tongTien       = getProp(d, "tongTien", 0);
            const giamGia        = getProp(d, "giamGia", 0);
            const thanhTien      = getProp(d, "thanhTien", 0);
            const daThu          = getProp(d, "daThu", 0);
            const conLai         = getProp(d, "conLai", 0);
            const tongNo         = getProp(d, "tongNoKhachHang", 0);
            const tongDonKhac    = getProp(d, "tongDonKhacDangGiao", 0);
            const diemThangNay   = getProp(d, "diemThangNay", -1);
            const diemThangTruoc = getProp(d, "diemThangTruoc", -1);

            let chiTiets = getProp(d, "chiTietHoaDons", []);
            if (!Array.isArray(chiTiets)) chiTiets = getProp(d, "ChiTietHoaDons", []);
            if (!Array.isArray(chiTiets)) chiTiets = [];

            return `
                <div class="detail-box">
                    <div class="detail-header">
                        <div class="detail-title">${ten}</div>
                        <div class="detail-sub">
                            ${diaChi ? `<div><i class="fa-solid fa-location-dot me-1"></i>${diaChi}</div>` : ""}
                            ${sdt    ? `<div><i class="fa-solid fa-phone me-1"></i>${sdt}</div>` : ""}
                        </div>
                    </div>

                    ${diemThangNay !== -1 || diemThangTruoc !== -1 ? `
                        <div class="detail-badges">
                            ${diemThangNay   !== -1 ? `<span class="badge bg-primary">Tháng này: ${diemThangNay}</span>` : ""}
                            ${diemThangTruoc !== -1 ? `<span class="badge bg-secondary ms-1">Tháng trước: ${diemThangTruoc}</span>` : ""}
                        </div>
                    ` : ""}

                    <div class="detail-items">
                        ${chiTiets.map(ct => {
                            let ctName      = firstNonEmpty(ct.TenSanPham, ct.tenSanPham, "");
                            let bienThe     = firstNonEmpty(ct.TenBienThe, ct.tenBienThe, "");
                            let toppingText = firstNonEmpty(ct.ToppingText, ct.toppingText, "");
                            let noteText    = firstNonEmpty(ct.NoteText, ct.noteText, "");
                            let soLuong     = ct.SoLuong ?? ct.soLuong ?? 0;
                            let tien        = ct.ThanhTien ?? ct.thanhTien ?? 0;
                            return `
                                <div class="detail-item">
                                    <div class="detail-item-top">
                                        <div class="detail-item-name">
                                            ${ctName}
                                            ${bienThe && bienThe !== "Size Chuẩn" ? `<span class="detail-variant">${bienThe}</span>` : ""}
                                        </div>
                                        <div class="detail-item-money">${money(tien)}</div>
                                    </div>
                                    <div class="detail-item-meta">
                                        SL: ${soLuong}
                                        ${toppingText ? `<div class="detail-line">${toppingText}</div>` : ""}
                                        ${noteText    ? `<div class="detail-line">${noteText}</div>`    : ""}
                                    </div>
                                </div>`;
                        }).join("")}
                    </div>

                    <div class="detail-footer">
                        <div class="detail-row"><span>Tổng cộng</span><span>${money(tongTien)}</span></div>
                        ${giamGia    > 0 ? `<div class="detail-row"><span>Giảm giá</span><span>${money(giamGia)}</span></div>`       : ""}
                        <div class="detail-row"><span>Thành tiền</span><span>${money(thanhTien)}</span></div>
                        ${daThu      > 0 ? `<div class="detail-row"><span>Đã thu</span><span>${money(daThu)}</span></div>`           : ""}
                        ${conLai     > 0 ? `<div class="detail-row"><span>Còn lại</span><span>${money(conLai)}</span></div>`         : ""}
                        ${tongNo     > 0 ? `<div class="detail-row"><span>Công nợ</span><span>${money(tongNo)}</span></div>`         : ""}
                        ${tongDonKhac> 0 ? `<div class="detail-row"><span>Đơn khác</span><span>${money(tongDonKhac)}</span></div>`   : ""}
                        ${ghiChu        ? `<div class="detail-note"><b>Ghi chú:</b> ${ghiChu}</div>`               : ""}
                        ${ghiChuShipper ? `<div class="detail-note"><b>Ghi chú shipper:</b> ${ghiChuShipper}</div>` : ""}
                    </div>
                </div>`;
        }

        function handleDocumentClick(ev) {
            if (openCardId == null) return;
            if (ev.target.closest(".swipe-wrapper")) return;
            closeCard(openCardId);
        }

        function handleSwipeStart(ev, id) {
            if (openCardId && openCardId !== id) closeCard(openCardId);
            let currentOffset = cardState[id] || 0;
            swipeState[id] = {
                startX: ev.clientX,
                startOffset: currentOffset,
                currentOffset: currentOffset,
                dragging: false
            };
            let wrapper = ev.currentTarget;
            if (wrapper?.setPointerCapture) {
                try { wrapper.setPointerCapture(ev.pointerId); } catch { }
            }
        }

        function handleSwipeMove(ev, id) {
            let state = swipeState[id];
            if (!state) return;
            let delta  = ev.clientX - state.startX;
            let offset = state.startOffset + delta;
            if (offset < -REVEAL_WIDTH) offset = -REVEAL_WIDTH;
            if (offset > 0) offset = 0;
            state.currentOffset = offset;
            if (Math.abs(offset - state.startOffset) > DRAG_THRESHOLD) state.dragging = true;
            let card = getCardEl(id);
            if (card) card.style.transform = `translateX(${offset}px)`;
        }

        function handleSwipeEnd(ev, id) {
            let state = swipeState[id];
            if (!state) return;
            let wrapper = ev.currentTarget;
            if (wrapper?.releasePointerCapture) {
                try { wrapper.releasePointerCapture(ev.pointerId); } catch { }
            }
            let offset      = state.currentOffset || 0;
            let finalOffset = 0;
            if (state.startOffset < 0) {
                if (offset > -REVEAL_WIDTH / 1.1) {
                    finalOffset = 0;
                    if (openCardId === id) openCardId = null;
                } else {
                    finalOffset = -REVEAL_WIDTH;
                    openCardId  = id;
                }
            } else {
                if (offset <= -OPEN_THRESHOLD) {
                    finalOffset = -REVEAL_WIDTH;
                    openCardId  = id;
                } else {
                    finalOffset = 0;
                    if (openCardId === id) openCardId = null;
                }
            }
            setCardOffset(id, finalOffset);
            if (state.dragging) clickBlock[id] = true;
            delete swipeState[id];
        }

        function handleSwipeCancel(ev, id) {
            let state = swipeState[id];
            if (!state) return;
            setCardOffset(id, state.startOffset || 0);
            if ((state.startOffset || 0) === 0 && openCardId === id) openCardId = null;
            delete swipeState[id];
        }

        function confirmAction(id, action) {
            if (!confirm("Xác nhận thực hiện?")) return;
            onAction(id, action);
        }

        function onAction(id, action) {
            let item = items.find(x => (x.Id || x.id) === id);
            if (!item) return;
            switch (action) {
                case "ESC":  showToast("ESC");            break;
                case "ESC2": showToast("ESC2");           break;
                case "Z":    quickPay(id, "TienMat");     break;
                case "A":    quickPay(id, "ChuyenKhoan"); break;
                case "B":    callF12(id, item);           break;
            }
        }

        async function quickPay(id, type) {
            let item = items.find(x => (x.Id || x.id) === id);
            if (!item) return;
            let amount = item.ConLai ?? item.conLai ?? 0;
            let phuongThuc = type === "ChuyenKhoan"
                ? "2CF9A88F-3BC0-4D4B-940D-F8FFA4AFFA02"
                : "0121FC04-0469-4908-8B9A-7002F860FB5C";
            try {
                let res = await fetch('?handler=Pay', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id,
                        khachHangId: item.KhachHangId || item.khachHangId,
                        ten: item.TenKhachHangText || item.tenKhachHangText,
                        soTien: amount,
                        phuongThucThanhToanId: phuongThuc
                    })
                });
                let r = await res.json();
                if (!r.isSuccess) throw "";
                if (openCardId === id) openCardId = null;
                delete cardState[id];
                delete swipeState[id];
                delete noteToggle[id];
                delete detailCache[id];
                delete clickBlock[id];
                items = items.filter(x => (x.Id || x.id) !== id);
                render();
            } catch {
                alert("Thanh toán thất bại");
            }
        }

        async function callF12(id, item) {
            try {
                let res = await fetch('?handler=F12', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, dto: item })
                });
                let r = await res.json();
                if (!r.isSuccess) throw "";
                let local = items.find(x => (x.Id || x.id) === id);
                if (local) {
                    local.NgayNo = local.NgayNo || new Date().toISOString();
                    local.ngayNo = local.ngayNo || local.NgayNo;
                }
                render();
            } catch {
                alert("Ghi nợ thất bại");
            }
        }

        function showToast(text) {
            let t = document.createElement("div");
            t.innerText = text;
            Object.assign(t.style, {
                position: "fixed", bottom: "100px", left: "50%",
                transform: "translateX(-50%)", background: "#111", color: "#fff",
                padding: "10px 16px", borderRadius: "8px", zIndex: "99999",
                boxShadow: "0 8px 24px rgba(0,0,0,.2)"
            });
            document.body.appendChild(t);
            setTimeout(() => t.remove(), 900);
        }

        function updateTime() {
            items.forEach(x => {
                let id = x.Id || x.id;
                let el = document.getElementById(`time-${id}`);
                if (!el) return;
                el.innerHTML = `<i class="fa fa-clock me-1"></i> ${renderTime(x)}`;
            });
        }

        document.addEventListener("click", handleDocumentClick);
        render();
        setInterval(updateTime, 1000);
    </script>
}

<style>
    .swipe-wrapper {
        position: relative;
        overflow: hidden;
        border-radius: 18px;
        touch-action: pan-y;
    }

    .actions {
        position: absolute;
        top: 0;
        bottom: 0;
        right: 0;
        display: flex;
        z-index: 1;
    }

        .actions button {
            width: 70px;
            border: none;
            height: 100%;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            flex-shrink: 0;
        }

            .actions button img {
                width: 48px;
                height: 48px;
                border-radius: 11px;
                object-fit: cover;
                pointer-events: none;
                box-shadow: 0 4px 10px rgba(0,0,0,.18);
            }

    .debt-card {
        position: relative;
        z-index: 2;
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        transition: transform .22s cubic-bezier(.22,1,.36,1);
        user-select: none;
        overflow: hidden;
        will-change: transform;
    }

        .debt-card:hover {
            box-shadow: 0 10px 28px rgba(0,0,0,.08);
        }

    .card-inner {
        padding: 16px;
    }

    .top-row {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .avatar {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        overflow: hidden;
        flex-shrink: 0;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .avatar i {
        font-size: 20px;
        color: white;
    }

    .info {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        min-width: 0;
    }

    .name {
        width: 100%;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .time {
        width: 100%;
        font-size: 13px;
        opacity: 0.7;
    }

    .amount {
        font-weight: 800;
        color: #ef4444;
        flex-shrink: 0;
