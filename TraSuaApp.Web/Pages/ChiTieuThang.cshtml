@page
@using TraSuaApp.Shared.Dtos
@model TraSuaAppWeb.Pages.ChiTieuThangModel
@{
    ViewData["Title"] = "Chi Tiêu Tháng";

    var currentDate = new DateTime(Model.Nam, Model.Thang, 1);
    var prev = currentDate.AddMonths(-1);
    var next = currentDate.AddMonths(1);
}

<div class="container-fluid mt-3">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a class="btn btn-outline-primary"
           href="?thang=@prev.Month&nam=@prev.Year">
            ← Tháng trước
        </a>

        <h4 class="mb-0 fw-bold">
            @Model.Thang/@Model.Nam
        </h4>

        <a class="btn btn-outline-primary"
           href="?thang=@next.Month&nam=@next.Year">
            Tháng sau →
        </a>
    </div>

    <!-- SEARCH + TOTAL -->
    <div class="d-flex mb-3 gap-2 align-items-center">
        <input type="text"
               id="searchBox"
               class="form-control"
               style="max-width:70%"
               placeholder="Tìm tên / ghi chú..."
               onkeyup="render()" />

        <div id="totalMoney"
             class="fw-bold text-danger text-end"
             style="min-width:150px">
            0 đ
        </div>
    </div>

    <!-- TABLE -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ngày</th>
                    <th>Nội dung</th>
                    <th>Loại</th>
                    <th class="text-end">Thành tiền</th>
                </tr>
            </thead>
            <tbody id="tbody"></tbody>

            <tfoot class="table-light">
                <tr>
                    <th colspan="3" class="text-end">Tổng:</th>
                    <th id="totalFooter" class="text-end text-danger fw-bold">0 đ</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        let items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items ?? new List<TraSuaApp.Shared.Dtos.ChiTieuHangNgayDto>()));

        function normalizeText(str) {
            return (str || "").toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/đ/g, 'd');
        }

        function render() {

            let key = normalizeText(document.getElementById("searchBox").value);

            let html = "";
            let total = 0;

            items.forEach(x => {

                let text = normalizeText((x.Ten || "") + " " + (x.GhiChu || ""));

                if (!text.includes(key)) return;

                total += (x.ThanhTien || 0);

                let loai = x.BillThang
                    ? '<span class="badge bg-primary">Tháng</span>'
                    : '<span class="badge bg-secondary">Lẻ</span>';

                html += `
                    <tr>
                        <td>${formatDate(x.NgayGio || x.Ngay)}</td>

                        <td>
                            <div class="ten">${escapeHtml(x.Ten || "")}</div>
                            ${x.GhiChu ? `<div class="ghichu">${escapeHtml(x.GhiChu)}</div>` : ""}
                        </td>

                        <td>${loai}</td>

                        <td class="text-end text-success fw-semibold">
                            ${money(x.ThanhTien)}
                        </td>
                    </tr>`;
            });

            document.getElementById("tbody").innerHTML = html;

            document.getElementById("totalMoney").innerText = money(total);
            document.getElementById("totalFooter").innerText = money(total);
        }

        function formatDate(d) {
            if (!d) return "";

            let dt = new Date(d);
            let day = dt.getDate();
            let month = dt.getMonth() + 1;
            let h = String(dt.getHours()).padStart(2, '0');
            let m = String(dt.getMinutes()).padStart(2, '0');

            return `${day}/${month} ${h}:${m}`;
        }

        function money(x) {
            return (x || 0).toLocaleString('vi-VN') + " đ";
        }

        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
        }

        render();
    </script>
}

<style>
    .ten {
        font-weight: 600;
    }

    .ghichu {
        font-size: 12px;
        font-style: italic;
        color: #6c757d;
        margin-top: 2px;
    }
</style>