@page
@using TraSuaApp.Infrastructure.Dtos
@model TraSuaAppWeb.Pages.ChietKhauThangModel
@{
    ViewData["Title"] = "Voucher Tháng";

    var currentDate = new DateTime(Model.Nam, Model.Thang, 1);
    var prev = currentDate.AddMonths(-1);
    var next = currentDate.AddMonths(1);
}

<div class="container-fluid mt-3">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a class="btn btn-outline-primary"
           href="?thang=@prev.Month&nam=@prev.Year">
            ← Tháng trước
        </a>

        <h4 class="mb-0 fw-bold">
            @Model.Thang/@Model.Nam
        </h4>

        <a class="btn btn-outline-primary"
           href="?thang=@next.Month&nam=@next.Year">
            Tháng sau →
        </a>
    </div>

    <!-- SEARCH + TOTAL -->
    <div class="d-flex mb-3 gap-2 align-items-center">
        <input type="text"
               id="searchBox"
               class="form-control"
               style="max-width:70%"
               placeholder="Tìm..."
               onkeyup="render()" />

        <div id="totalMoney"
             class="fw-bold fs-5 text-danger ms-auto text-end"
             style="min-width: 120px;">
            0 đ
        </div>
    </div>

    <!-- TABLE -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle" style="table-layout: fixed; width: 100%;">
            <colgroup>
                <col style="width: 18%;">
                <col style="width: 62%;">
                <col style="width: 20%;">
            </colgroup>
            <thead class="table-light">
                <tr>
                    <th>Ngày giờ</th>
                    <th>Nội dung</th>
                    <th class="text-end">Thành tiền</th>
                </tr>
            </thead>

            <tbody id="tbody"></tbody>

            <tfoot class="table-light">
                <tr>
                    <th colspan="2" class="text-end">Tổng:</th>
                    <th id="totalFooter" class="text-end text-danger fw-bold">0</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        let items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items ?? new List<TraSuaApp.Infrastructure.Dtos.VoucherThangDto>()));

        function normalizeText(str) {
            return (str || "")
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/đ/g, 'd')
                .replace(/[^a-z0-9\s]/g, '')
                .replace(/\s+/g, ' ')
                .trim();
        }

        function render() {
            let key = normalizeText(document.getElementById("searchBox").value);

            let html = "";
            let total = 0;

            items.forEach(x => {
                let text = normalizeText((x.TenKhachHangText || "") + " " + (x.GhiChu || ""));
                if (!text.includes(key)) return;

                total += (x.GiamGia || 0);

                html += `
                    <tr>
                        <td>${formatDate(x.NgayGio)}</td>

                        <td>
                            <div class="ten">${escapeHtml(x.TenKhachHangText || "Khách lẻ")}</div>
                            ${x.GhiChu ? `<div class="ghichu">${escapeHtml(x.GhiChu)}</div>` : ""}
                        </td>

                        <td class="text-end text-success fw-semibold">
                            ${money(x.GiamGia)}
                        </td>
                    </tr>`;
            });

            document.getElementById("tbody").innerHTML = html;
            document.getElementById("totalMoney").innerText = money(total);
            document.getElementById("totalFooter").innerText = money(total);
        }

        function formatDate(d) {
            if (!d) return "";

            let dt = new Date(d);
            let day = String(dt.getDate()).padStart(2, '0');
            let month = String(dt.getMonth() + 1).padStart(2, '0');
            let year = String(dt.getFullYear()).slice(-2);
            let h = String(dt.getHours()).padStart(2, '0');
            let m = String(dt.getMinutes()).padStart(2, '0');

            return `
                <div>${day}/${month}/${year}</div>
                <div class="time-sub">
                    <i class="fa fa-clock"></i> ${h}:${m}
                </div>
            `;
        }

        function money(x) {
            return (x || 0).toLocaleString('vi-VN');
        }

        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
        }

        render();
    </script>
}

<style>
    .ten {
        font-weight: 600;
    }

    .ghichu {
        font-size: 12px;
        font-style: italic;
        color: #6c757d;
        margin-top: 2px;
    }

    .time-sub {
        font-size: 12px;
        color: #6c757d;
        margin-top: 2px;
        display: flex;
        align-items: center;
        gap: 4px;
    }
</style>